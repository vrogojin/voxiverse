+// COSMOS R2.1: install/clear the frozen-per-epoch near-field bake. `d` is CosmosTruePlace.pack_bake_params
+// flattened to plain packed arrays (no chart topology crosses here — see cosmos_bake.h). enabled=false (or
+// an empty dict) restores the plain flat mesher exactly. Written under the parameters write-lock so the mesh
+// workers pick up the whole frozen blob atomically via their build() snapshot.
+// Definition of the cosmos identity-local flag declared in cosmos_bake.h (main-thread only; see there).
+bool g_cosmos_identity_local = false;
+
+void VoxelMesherBlocky::set_cosmos_bake(Dictionary d) {
+	CosmosBakeParams cb;
+	cb.enabled = bool(d.get("enabled", false));
+	if (cb.enabled) {
+		cb.n = int(d.get("n", 1));
+		cb.R = float(d.get("R", 1.0));
+		cb.home = int(d.get("home", 0));
+		const PackedInt32Array mw = d.get("mw", PackedInt32Array());
+		for (int i = 0; i < 4 && i < mw.size(); ++i) {
+			cb.mw[i] = mw[i];
+		}
+		const PackedInt32Array eb = d.get("edge_b", PackedInt32Array());
+		const PackedFloat32Array em = d.get("edge_m", PackedFloat32Array());
+		const PackedFloat32Array et = d.get("edge_t", PackedFloat32Array());
+		for (int s = 0; s < 4; ++s) {
+			if (s < eb.size()) {
+				cb.edges[s].b = eb[s];
+			}
+			for (int k = 0; k < 4; ++k) {
+				if (s * 4 + k < em.size()) {
+					cb.edges[s].m[k] = em[s * 4 + k];
+				}
+			}
+			for (int k = 0; k < 2; ++k) {
+				if (s * 2 + k < et.size()) {
+					cb.edges[s].t[k] = et[s * 2 + k];
+				}
+			}
+		}
+		const PackedFloat32Array an = d.get("axis_n", PackedFloat32Array());
+		const PackedFloat32Array au = d.get("axis_u", PackedFloat32Array());
+		const PackedFloat32Array av = d.get("axis_v", PackedFloat32Array());
+		for (int f = 0; f < 6; ++f) {
+			for (int k = 0; k < 3; ++k) {
+				if (f * 3 + k < an.size()) {
+					cb.axis_n[f][k] = an[f * 3 + k];
+				}
+				if (f * 3 + k < au.size()) {
+					cb.axis_u[f][k] = au[f * 3 + k];
+				}
+				if (f * 3 + k < av.size()) {
+					cb.axis_v[f][k] = av[f * 3 + k];
+				}
+			}
+		}
+		const PackedFloat32Array dc = d.get("dcam", PackedFloat32Array());
+		for (int k = 0; k < 3 && k < dc.size(); ++k) {
+			cb.dcam[k] = dc[k];
+		}
+		cb.ycam = float(d.get("ycam", 0.0));
+		const PackedFloat32Array mt = d.get("mt", PackedFloat32Array());
+		for (int r = 0; r < 3; ++r) {
+			for (int c = 0; c < 3; ++c) {
+				if (r * 3 + c < mt.size()) {
+					cb.mt_row[r][c] = mt[r * 3 + c];
+				}
+			}
+		}
+	}
+	g_cosmos_identity_local = cb.enabled; // drives VoxelMeshBlock block-instance placement (main thread)
+	RWLockWrite wlock(_parameters_lock);
+	_parameters.cosmos = cb;
+}
+
+Vector3 VoxelMesherBlocky::cosmos_debug_place(double vx, double vy, double vz) const {
+	CosmosBakeParams cb;
+	{
+		RWLockRead rlock(_parameters_lock);
+		cb = _parameters.cosmos;
+	}
+	Vector3 out;
+	if (cosmos_bake_place(cb, vx, vy, vz, out)) {
+		return out;
+	}
+	return Vector3(1.0e18, 1.0e18, 1.0e18); // wedge sentinel (matches CosmosTruePlace._WEDGE)
+}
