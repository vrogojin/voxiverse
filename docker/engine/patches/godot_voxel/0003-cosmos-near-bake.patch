+// COSMOS R2.1 — near-field real-geometry bake (docs/COSMOS-REAL-GEOMETRY-STUDY §2).
+//
+// A DIRECT transcription of CosmosTruePlace.bake_place_packed / bake_radial_packed (GDScript), which is
+// proven == place_true across home cells, all four edge folds, and the corner-wedge by the headless gate
+// verify_cosmos_bake_mirror (4/0). ALL cube topology (fold table + face axes) is precomputed GDScript-side
+// and pushed here as flat numbers, so this file does PURE ARITHMETIC — no topology logic, no branches that
+// can get a sign/index wrong (the exact class that scrambled the M5a shader twice). Frozen per epoch and
+// snapshotted under the mesher's Parameters lock, so worker threads read an immutable copy.
+//
+// Coordinate identity (why no origin term): for M_win in C4 (orthonormal), raw(node_origin + v) = M_win*v
+// exactly, so a terrain-local voxel index v maps to the raw home-face index p = mw*v directly.
+
+#ifndef COSMOS_BAKE_H
+#define COSMOS_BAKE_H
+
+#include <core/math/vector3.h>
+#include <cmath>
+
+namespace zylann::voxel {
+
+constexpr double COSMOS_PI = 3.14159265358979323846;
+
+// Set by VoxelMesherBlocky::set_cosmos_bake (main thread) = cosmos.enabled; read by
+// VoxelMeshBlock::set_parent_transform (main thread) to place baked blocks at IDENTITY-local — their mesh
+// verts are already absolute epoch-frame coords, so the block instance must NOT re-add its window origin.
+extern bool g_cosmos_identity_local;
+
+// The frozen-per-epoch bake blob (mirror of CosmosTruePlace.pack_bake_params). Row-major mt.
+struct CosmosBakeParams {
+	bool enabled = false;
+	int n = 1;
+	float R = 1.0f;
+	int home = 0;
+	int mw[4] = { 1, 0, 0, 1 }; // M_win row-major [a,b,c,d]
+
+	// The home face's 4 edge remaps, side order 0=EAST(px>=n),1=WEST(px<0),2=NORTH(pz>=n),3=SOUTH(pz<0).
+	struct Edge {
+		int b = 0; // neighbour face
+		float m[4] = { 1, 0, 0, 1 };
+		float t[2] = { 0, 0 };
+	} edges[4];
+
+	// Per-face axes N,U,V for all 6 faces (so the folded face indexes directly). Layout per face: n,u,v.
+	float axis_n[6][3] = {};
+	float axis_u[6][3] = {};
+	float axis_v[6][3] = {};
+
+	// Epoch frame (frozen at the last flip): d_cam, y_cam, and mt as 3 ROWS (mt*rel = row_i . rel).
+	float dcam[3] = { 0, 1, 0 };
+	float ycam = 0.0f;
+	float mt_row[3][3] = { { 1, 0, 0 }, { 0, 1, 0 }, { 0, 0, 1 } };
+};
+
+// Fold + gnomonic direction of a terrain-local voxel index (vx,vz). Returns false for a double-out corner
+// (wedge). On success, `dir` is the UNIT sphere direction. Mirrors _fold_f + _dir_of exactly.
+inline bool cosmos_bake_dir(const CosmosBakeParams &p, double vx, double vz, Vector3 &dir) {
+	const double nf = double(p.n);
+	const double px = double(p.mw[0]) * vx + double(p.mw[1]) * vz;
+	const double pz = double(p.mw[2]) * vx + double(p.mw[3]) * vz;
+	const bool oi = px < 0.0 || px >= nf;
+	const bool oj = pz < 0.0 || pz >= nf;
+	if (oi && oj) {
+		return false; // corner wedge
+	}
+	int face;
+	double fx, fz;
+	if (!oi && !oj) {
+		face = p.home;
+		fx = px;
+		fz = pz;
+	} else {
+		int side;
+		if (px >= nf) {
+			side = 0;
+		} else if (px < 0.0) {
+			side = 1;
+		} else if (pz >= nf) {
+			side = 2;
+		} else {
+			side = 3;
+		}
+		const CosmosBakeParams::Edge &e = p.edges[side];
+		face = e.b;
+		fx = double(e.m[0]) * px + double(e.m[1]) * pz + double(e.t[0]);
+		fz = double(e.m[2]) * px + double(e.m[3]) * pz + double(e.t[1]);
+	}
+	const double a = 2.0 * fx / nf - 1.0;
+	const double b = 2.0 * fz / nf - 1.0;
+	const double u = std::tan(a * (COSMOS_PI / 4.0));
+	const double w = std::tan(b * (COSMOS_PI / 4.0));
+	const float *N = p.axis_n[face];
+	const float *U = p.axis_u[face];
+	const float *V = p.axis_v[face];
+	Vector3 d(
+			double(N[0]) + u * double(U[0]) + w * double(V[0]),
+			double(N[1]) + u * double(U[1]) + w * double(V[1]),
+			double(N[2]) + u * double(U[2]) + w * double(V[2]));
+	dir = d.normalized();
+	return true;
+}
+
+inline Vector3 cosmos_mt_xform(const CosmosBakeParams &p, const Vector3 &rel) {
+	return Vector3(
+			p.mt_row[0][0] * rel.x + p.mt_row[0][1] * rel.y + p.mt_row[0][2] * rel.z,
+			p.mt_row[1][0] * rel.x + p.mt_row[1][1] * rel.y + p.mt_row[1][2] * rel.z,
+			p.mt_row[2][0] * rel.x + p.mt_row[2][1] * rel.y + p.mt_row[2][2] * rel.z);
+}
+
+// True epoch-frame position of terrain-local voxel index (vx,vy,vz). Returns false for a wedge vertex
+// (caller culls its triangles). Mirrors bake_place_packed.
+inline bool cosmos_bake_place(const CosmosBakeParams &p, double vx, double vy, double vz, Vector3 &out_pos) {
+	Vector3 d;
+	if (!cosmos_bake_dir(p, vx, vz, d)) {
+		return false;
+	}
+	const double rr = double(p.R);
+	const Vector3 dc(p.dcam[0], p.dcam[1], p.dcam[2]);
+	const Vector3 rel = d * rr - dc * rr + d * vy - dc * double(p.ycam);
+	out_pos = cosmos_mt_xform(p, rel);
+	return true;
+}
+
+// Outward radial normal (mt*d̂ normalized) — the v1 near normal (matches the far layer; ambient-lit scene
+// so slope-exact normals are cosmetically negligible). Mirrors bake_radial_packed.
+inline bool cosmos_bake_radial(const CosmosBakeParams &p, double vx, double vz, Vector3 &out_n) {
+	Vector3 d;
+	if (!cosmos_bake_dir(p, vx, vz, d)) {
+		return false;
+	}
+	out_n = cosmos_mt_xform(p, d).normalized();
+	return true;
+}
+
+} // namespace zylann::voxel
+
+#endif // COSMOS_BAKE_H
