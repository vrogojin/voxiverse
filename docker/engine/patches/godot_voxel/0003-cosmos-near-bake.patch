+	// COSMOS R2.1: near-field real-geometry bake (docs/COSMOS-REAL-GEOMETRY-STUDY §2). Transform every
+	// vertex from window space to its true epoch-frame sphere position — a CPU transcription of place_true,
+	// validated headlessly by verify_cosmos_bake_mirror (mirror == place_true, 4/0) — and DROP triangles
+	// touching a double-out corner wedge (the corner-closure theorem guarantees the strips still close, so
+	// no hole). The window→true map is orientation-REVERSING (negative-determinant reflection: the sphere
+	// radial is the middle axis), which flips triangle winding under CULL_BACK → faces render inward; so we
+	// swap b↔c on every kept triangle, exactly as the far bake does. Normal = the outward radial (mt·d̂),
+	// the far layer's proven-acceptable v1 normal in this ambient-lit scene. Runs on the mesh worker with a
+	// per-mesher frozen params snapshot (thread-safe). Disabled → the flat mesher is byte-identical.
+	if (params.cosmos.enabled) {
+		const CosmosBakeParams &cb = params.cosmos;
+		const Vector3i wo = input.origin_in_voxels; // block's window voxel origin
+		for (Arrays &arrays : arrays_per_material) {
+			const unsigned int vcount = (unsigned int)arrays.positions.size();
+			if (vcount == 0) {
+				continue;
+			}
+			const bool has_normals = (arrays.normals.size() == vcount);
+			StdVector<uint8_t> is_wedge;
+			is_wedge.resize(vcount);
+			for (unsigned int i = 0; i < vcount; ++i) {
+				const Vector3f lp = arrays.positions[i]; // window-local (captured by value before overwrite)
+				const double vx = double(wo.x) + double(lp.x);
+				const double vy = double(wo.y) + double(lp.y);
+				const double vz = double(wo.z) + double(lp.z);
+				Vector3 tp;
+				if (cosmos_bake_place(cb, vx, vy, vz, tp)) {
+					arrays.positions[i] = Vector3f((float)tp.x, (float)tp.y, (float)tp.z);
+					if (has_normals) {
+						Vector3 tn;
+						if (cosmos_bake_radial(cb, vx, vz, tn)) {
+							arrays.normals[i] = Vector3f((float)tn.x, (float)tn.y, (float)tn.z);
+						}
+					}
+					is_wedge[i] = 0;
+				} else {
+					arrays.positions[i] = Vector3f(0.f, 0.f, 0.f); // unreferenced once its triangles are culled
+					is_wedge[i] = 1;
+				}
+			}
+			// Rebuild indices: drop wedge-touching triangles, reverse winding (b↔c) on the rest.
+			StdVector<int> &idx = arrays.indices;
+			unsigned int w = 0;
+			for (unsigned int t = 0; t + 3 <= (unsigned int)idx.size(); t += 3) {
+				const int ia = idx[t];
+				const int ib = idx[t + 1];
+				const int ic = idx[t + 2];
+				if (is_wedge[ia] || is_wedge[ib] || is_wedge[ic]) {
+					continue;
+				}
+				idx[w++] = ia;
+				idx[w++] = ic;
+				idx[w++] = ib;
+			}
+			idx.resize(w);
+			// Every triangle culled (a fully-wedge corner block): clear the arrays so the surface loop below
+			// skips it (its `positions.size() != 0` guard) — an indexed surface with 0 indices errors on
+			// upload with NO_INDEX_ARRAY (the same class fixed in the far bake).
+			if (w == 0) {
+				arrays.clear();
+			}
+		}
+	}
