+// COSMOS FP-CARVE (docs/COSMOS-FACETED-CARVE.md, patch 0004): install/clear the frozen-per-crossing facet
+// carve blob. `d` = {enabled, planes:PackedFloat64Array(16), arid_base, arid_count}. Written under the write
+// lock so mesh workers pick up the whole blob atomically via their build() snapshot; the push happens INSIDE
+// module_world set_facet BEFORE restream() (B7), so no in-flight block ever meshes with a stale facet.
+void VoxelMesherBlocky::set_facet_carve(Dictionary d) {
+	FacetCarveParams fc;
+	fc.enabled = bool(d.get("enabled", false));
+	if (fc.enabled) {
+		fc.arid_base = int(d.get("arid_base", 0));
+		fc.arid_count = int(d.get("arid_count", 0));
+		const PackedFloat64Array planes = d.get("planes", PackedFloat64Array());
+		for (int s = 0; s < 4; ++s) {
+			for (int k = 0; k < 4; ++k) {
+				if (s * 4 + k < planes.size()) {
+					fc.plane[s][k] = planes[s * 4 + k];
+				}
+			}
+		}
+	}
+	RWLockWrite wlock(_parameters_lock);
+	_parameters.facet_carve = fc;
+}
+
+Dictionary VoxelMesherBlocky::get_facet_carve() const {
+	FacetCarveParams fc;
+	{
+		RWLockRead rlock(_parameters_lock);
+		fc = _parameters.facet_carve;
+	}
+	Dictionary d;
+	d["enabled"] = fc.enabled;
+	d["arid_base"] = fc.arid_base;
+	d["arid_count"] = fc.arid_count;
+	PackedFloat64Array planes;
+	planes.resize(16);
+	{
+		double *w = planes.ptrw();
+		for (int s = 0; s < 4; ++s) {
+			for (int k = 0; k < 4; ++k) {
+				w[s * 4 + k] = fc.plane[s][k];
+			}
+		}
+	}
+	d["planes"] = planes;
+	return d;
+}
+
+Dictionary VoxelMesherBlocky::facet_carve_debug_cell(int x, int y, int z) const {
+	FacetCarveParams fc;
+	{
+		RWLockRead rlock(_parameters_lock);
+		fc = _parameters.facet_carve;
+	}
+	Dictionary d;
+	PackedVector3Array verts;
+	PackedVector3Array normals;
+	PackedVector2Array uvs;
+	PackedInt32Array indices;
+	double clocal[4][4];
+	int pc = 0;
+	const FacetCellClass fcls = facet_cell_state(fc, double(x), double(y), double(z), clocal, pc);
+	d["class"] = int(fcls);
+	if (fcls == FACET_CELL_STRADDLE) {
+		FacetCarveFace cfaces[10];
+		const int fcount = facet_clip_cube(clocal, pc, cfaces);
+		for (int fi = 0; fi < fcount; ++fi) {
+			const FacetCarveFace &face = cfaces[fi];
+			if (face.count < 3) {
+				continue;
+			}
+			const int base = verts.size();
+			for (int i = 0; i < face.count; ++i) {
+				verts.push_back(Vector3(face.pts[i].x, face.pts[i].y, face.pts[i].z));
+				normals.push_back(Vector3(face.normal.x, face.normal.y, face.normal.z));
+				const Vector2f uv = facet_face_uv(face.pts[i], face.normal);
+				uvs.push_back(Vector2(uv.x, uv.y));
+			}
+			for (int i = 1; i + 1 < face.count; ++i) {
+				indices.push_back(base + 0);
+				indices.push_back(base + i);
+				indices.push_back(base + i + 1);
+			}
+		}
+	}
+	d["verts"] = verts;
+	d["normals"] = normals;
+	d["uvs"] = uvs;
+	d["indices"] = indices;
+	return d;
+}
