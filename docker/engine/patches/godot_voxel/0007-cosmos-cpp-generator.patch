+#include "voxel_generator_cosmos.h"
+#include "../../util/godot/classes/noise.h"
+#include "cosmos_terrain.h"
+
+#include <core/variant/dictionary.h>
+
+#include <cmath>
+
+namespace zylann::voxel {
+
+namespace {
+
+// Pull a required Ref<Noise> out of the config. Missing/wrong-typed -> null, which fails setup().
+// Deliberately strict: a generator that silently ran with five of six noises would produce terrain
+// that is *plausible* and wrong, and plausible-and-wrong is the one failure mode the byte-equality
+// gate exists to make impossible.
+Ref<Noise> get_noise_param(const Dictionary &config, const char *key) {
+	if (!config.has(key)) {
+		return Ref<Noise>();
+	}
+	return Ref<Noise>(config[key]);
+}
+
+PackedInt32Array get_i32_param(const Dictionary &config, const char *key) {
+	if (!config.has(key)) {
+		return PackedInt32Array();
+	}
+	return PackedInt32Array(config[key]);
+}
+
+} // namespace
+
+VoxelGeneratorCosmos::VoxelGeneratorCosmos() {}
+
+VoxelGeneratorCosmos::~VoxelGeneratorCosmos() {}
+
+bool VoxelGeneratorCosmos::setup(Dictionary config) {
+	Parameters p;
+
+	p.hills = get_noise_param(config, "hills");
+	p.detail = get_noise_param(config, "detail");
+	p.continent = get_noise_param(config, "continent");
+	p.temperature = get_noise_param(config, "temperature");
+	p.humidity = get_noise_param(config, "humidity");
+	p.mountain = get_noise_param(config, "mountain");
+
+	// All six or nothing. See get_noise_param's comment: a partial noise stack is worse than none.
+	if (p.hills.is_null() || p.detail.is_null() || p.continent.is_null() || p.temperature.is_null() ||
+			p.humidity.is_null() || p.mountain.is_null()) {
+		ERR_PRINT("VoxelGeneratorCosmos.setup: incomplete noise stack; generator stays disabled.");
+		return false;
+	}
+
+	p.seed = int(config.get("seed", 0));
+	p.gen_face = int(config.get("gen_face", 0));
+	p.gen_n = int(config.get("gen_n", 0));
+	p.gen_facet = int(config.get("gen_facet", -1));
+	p.flat_world = bool(config.get("flat_world", true));
+
+	p.cube_arid = get_i32_param(config, "cube_arid");
+	p.gen_arid = get_i32_param(config, "gen_arid");
+	p.snow_arid = get_i32_param(config, "snow_arid");
+	p.layer_arid = get_i32_param(config, "layer_arid");
+	p.slope_arid = get_i32_param(config, "slope_arid");
+	p.snow_slope_arid = get_i32_param(config, "snow_slope_arid");
+	p.carve_arid = get_i32_param(config, "carve_arid");
+	p.carve_snow_arid = get_i32_param(config, "carve_snow_arid");
+	p.surface_arid = get_i32_param(config, "surface_arid");
+	p.block_ids = get_i32_param(config, "block_ids");
+
+	p.model_count = int(config.get("model_count", 0));
+	p.waterlog = bool(config.get("waterlog", false));
+
+	p.faceted = bool(config.get("faceted", false));
+	p.m5c_corner = bool(config.get("m5c_corner", false));
+
+	p.facet_frame = PackedFloat64Array(config.get("facet_frame", PackedFloat64Array()));
+	p.facet_off = get_i32_param(config, "facet_off");
+	p.facet_r_blocks = double(config.get("facet_r_blocks", 0.0));
+
+	p.id_wood = int(config.get("id_wood", 0));
+	p.id_leaf = int(config.get("id_leaf", 0));
+	p.id_spruce_log = int(config.get("id_spruce_log", 0));
+	p.id_spruce_leaf = int(config.get("id_spruce_leaf", 0));
+	p.id_birch_log = int(config.get("id_birch_log", 0));
+	p.id_birch_leaf = int(config.get("id_birch_leaf", 0));
+
+	p.id_bedrock = int(config.get("id_bedrock", 0));
+	p.id_deepslate = int(config.get("id_deepslate", 0));
+	p.id_water = int(config.get("id_water", 0));
+	p.id_lava = int(config.get("id_lava", 0));
+	p.id_ice = int(config.get("id_ice", 0));
+	p.id_sand = int(config.get("id_sand", 0));
+	p.id_red_sand = int(config.get("id_red_sand", 0));
+	p.id_gravel = int(config.get("id_gravel", 0));
+	p.id_sandstone = int(config.get("id_sandstone", 0));
+	p.id_red_sandstone = int(config.get("id_red_sandstone", 0));
+	p.id_snow = int(config.get("id_snow", 0));
+	p.id_mud = int(config.get("id_mud", 0));
+	p.id_podzol = int(config.get("id_podzol", 0));
+	p.id_sulfur = int(config.get("id_sulfur", 0));
+	p.id_cinnabar = int(config.get("id_cinnabar", 0));
+	p.id_stone = int(config.get("id_stone", 0));
+	p.id_dirt = int(config.get("id_dirt", 0));
+	p.id_grass = int(config.get("id_grass", 0));
+	p.strata_seq = get_i32_param(config, "strata_seq");
+	p.band_seq = get_i32_param(config, "band_seq");
+	p.ore_stone = get_i32_param(config, "ore_stone");
+	p.ore_deep = get_i32_param(config, "ore_deep");
+	p.solidity = PackedFloat64Array(config.get("solidity", PackedFloat64Array()));
+	p.state_mask = get_i32_param(config, "state_mask");
+	p.liquid_lrid_water = int(config.get("liquid_lrid_water", -1));
+	p.liquid_lrid_lava = int(config.get("liquid_lrid_lava", -1));
+	p.block_count = int(config.get("block_count", 0));
+
+	// The cube table and the block-id table are the two the emit loop cannot function without.
+	if (p.cube_arid.size() == 0 || p.block_ids.size() == 0) {
+		ERR_PRINT("VoxelGeneratorCosmos.setup: missing cube_arid/block_ids; generator stays disabled.");
+		return false;
+	}
+
+	// REFUSE what is not ported, rather than generate a different planet quietly.
+	//
+	// column_profile_core implements two of TerrainConfig.column_profile's three branches: faceted
+	// (facet_profile -> profile_at_dir) and flat 2D. The third -- the non-faceted CURVED branch
+	// (_curved_profile, with LatticeNav edge folding and the M5C pillar override) -- is NOT ported.
+	// It is unreachable in the shipped build (FLAT_WORLD stays true; faceted implies flat), so this
+	// costs nothing today. But an un-ported branch that silently falls through to the flat formula
+	// would produce a coherent, plausible, WRONG world -- the failure mode the byte-equality gate
+	// exists to prevent, and one that would be caught only after shipping. So: hard refusal.
+	if (!p.flat_world) {
+		ERR_PRINT("VoxelGeneratorCosmos.setup: the non-faceted CURVED branch (_curved_profile / "
+				  "LatticeNav folding) is not ported; refusing rather than emitting a different planet.");
+		return false;
+	}
+	if (p.faceted) {
+		// Faceted needs the frozen atlas: 12 doubles + 2 ints per facet. Validate it as a WHOLE (rather
+		// than only far enough to cover gen_facet), because any facet may legitimately be sampled: §7.2's
+		// sample_columns takes an fid so a skin tile can cover facets the workers are not homed on.
+		p.facet_count = int(p.facet_frame.size() / 12);
+		if (p.facet_count <= 0 || p.facet_frame.size() != int64_t(p.facet_count) * 12 ||
+				p.facet_off.size() != int64_t(p.facet_count) * 2) {
+			ERR_PRINT("VoxelGeneratorCosmos.setup: faceted epoch without a well-formed frozen facet atlas "
+					  "(facet_frame/facet_off size mismatch); generator stays disabled.");
+			return false;
+		}
+		if (p.gen_facet < 0 || p.gen_facet >= p.facet_count) {
+			ERR_PRINT("VoxelGeneratorCosmos.setup: faceted epoch's gen_facet is outside the frozen atlas; "
+					  "generator stays disabled.");
+			return false;
+		}
+		if (!(p.facet_r_blocks > 0.0)) {
+			ERR_PRINT("VoxelGeneratorCosmos.setup: faceted epoch needs facet_r_blocks > 0; disabled.");
+			return false;
+		}
+	}
+
+	p.ready = true;
+
+	{
+		RWLockWrite wlock(_params_lock);
+		_params = p;
+	}
+	return true;
+}
+
+bool VoxelGeneratorCosmos::is_ready() const {
+	RWLockRead rlock(_params_lock);
+	return _params.ready;
+}
+
+Dictionary VoxelGeneratorCosmos::get_setup_digest() const {
+	RWLockRead rlock(_params_lock);
+	Dictionary d;
+	d["ready"] = _params.ready;
+	d["seed"] = _params.seed;
+	d["gen_face"] = _params.gen_face;
+	d["gen_n"] = _params.gen_n;
+	d["gen_facet"] = _params.gen_facet;
+	d["flat_world"] = _params.flat_world;
+	d["model_count"] = _params.model_count;
+	d["waterlog"] = _params.waterlog;
+	d["cube_arid_size"] = _params.cube_arid.size();
+	d["gen_arid_size"] = _params.gen_arid.size();
+	d["snow_arid_size"] = _params.snow_arid.size();
+	d["layer_arid_size"] = _params.layer_arid.size();
+	d["slope_arid_size"] = _params.slope_arid.size();
+	d["snow_slope_arid_size"] = _params.snow_slope_arid.size();
+	d["carve_arid_size"] = _params.carve_arid.size();
+	d["carve_snow_arid_size"] = _params.carve_snow_arid.size();
+	d["surface_arid_size"] = _params.surface_arid.size();
+	d["block_ids_size"] = _params.block_ids.size();
+	d["noise_ok"] = _params.continent.is_valid() && _params.hills.is_valid() && _params.detail.is_valid() &&
+			_params.temperature.is_valid() && _params.humidity.is_valid() && _params.mountain.is_valid();
+
+	// Round-trip one noise sample through the SAME call the port will use. This is the S1 proof that
+	// decision (1) in the header holds end-to-end: verify_cppgen.gd compares this against GDScript's
+	// `_continent.get_noise_2d(0.0, 0.0)` and friends. If these ever differ, the whole port's
+	// byte-equality argument is void and the port must stop -- so it is worth one bound call to know.
+	if (_params.continent.is_valid()) {
+		d["probe_continent_2d"] = double(_params.continent->get_noise_2d(12.0, -7.0));
+		d["probe_continent_3d"] = double(_params.continent->get_noise_3d(12.0, -7.0, 33.0));
+	}
+	if (_params.mountain.is_valid()) {
+		d["probe_mountain_2d"] = double(_params.mountain->get_noise_2d(12.0, -7.0));
+	}
+	if (_params.hills.is_valid()) {
+		d["probe_hills_2d"] = double(_params.hills->get_noise_2d(12.0, -7.0));
+	}
+	if (_params.detail.is_valid()) {
+		d["probe_detail_2d"] = double(_params.detail->get_noise_2d(12.0, -7.0));
+	}
+	if (_params.temperature.is_valid()) {
+		d["probe_temperature_2d"] = double(_params.temperature->get_noise_2d(12.0, -7.0));
+	}
+	if (_params.humidity.is_valid()) {
+		d["probe_humidity_2d"] = double(_params.humidity->get_noise_2d(12.0, -7.0));
+	}
+	return d;
+}
+
+// ================================================================================================
+// THE ONE CORE (SEAMLESS-SCALES §7.1). Every entry point below is a thin loop over these.
+//
+// S2 scope: the pure column math -- column_profile (flat + faceted/sphere) and slope_run_of, with
+// the TreeGen stencil that slope firing depends on. Transcribed line-for-line from TerrainConfig /
+// TreeGen; see cosmos_terrain.h for the four transcription traps that govern every line here.
+// ================================================================================================
+
+// --- FacetAtlas.cell_dir: PURE ARITHMETIC over the frozen frame (see Parameters::facet_frame) ---
+// Port of facet_atlas.gd:246. `_frame` layout per facet: [0..2] origin, [3..5] du, [6..8] dw(y),
+// [9..11] dv. All f64, and normalized() in f64 -- CubeSphere.DVec3 is a script f64 vector, NOT a
+// Godot Vector3 (which is f32). Routing this through Vector3 would silently f32-quantize the
+// direction and move the terrain.
+void VoxelGeneratorCosmos::cell_dir(
+		const Parameters &p, int fid, int x, int z, double &out_x, double &out_y, double &out_z) {
+	const int f = fid * 12;
+	const double fx = double(x) - double(p.facet_off[fid * 2]) + 0.5;
+	const double fz = double(z) - double(p.facet_off[fid * 2 + 1]) + 0.5;
+	double dx = p.facet_frame[f + 0] + fx * p.facet_frame[f + 3] + fz * p.facet_frame[f + 9];
+	double dy = p.facet_frame[f + 1] + fx * p.facet_frame[f + 4] + fz * p.facet_frame[f + 10];
+	double dz = p.facet_frame[f + 2] + fx * p.facet_frame[f + 5] + fz * p.facet_frame[f + 11];
+	// DVec3.normalized(): length() in f64, and the l == 0.0 guard returns a ZERO vector (not the
+	// input). Mirrored exactly -- an ordinary "if (l > 0)" would differ on the degenerate case.
+	const double l = Math::sqrt(dx * dx + dy * dy + dz * dz);
+	if (l == 0.0) {
+		out_x = 0.0;
+		out_y = 0.0;
+		out_z = 0.0;
+		return;
+	}
+	out_x = dx / l;
+	out_y = dy / l;
+	out_z = dz / l;
+}
+
+// Port of TerrainConfig._mountain_factor (2D, flat world).
+double VoxelGeneratorCosmos::mountain_factor(const Parameters &p, double c, double fx, double fz) {
+	const double m = cosmos::smoothstep(
+			cosmos::MOUNTAIN_MASK_LO, cosmos::MOUNTAIN_MASK_HI, p.mountain->get_noise_2d(fx, fz));
+	if (m <= 0.0) {
+		return 0.0;
+	}
+	return m * cosmos::smoothstep(cosmos::MOUNTAIN_C_LO, cosmos::MOUNTAIN_C_HI, c);
+}
+
+// Port of TerrainConfig._mountain_factor3 (3D, sphere).
+double VoxelGeneratorCosmos::mountain_factor3(
+		const Parameters &p, double c, double px, double py, double pz) {
+	const double m = cosmos::smoothstep(
+			cosmos::MOUNTAIN_MASK_LO, cosmos::MOUNTAIN_MASK_HI, p.mountain->get_noise_3d(px, py, pz));
+	if (m <= 0.0) {
+		return 0.0;
+	}
+	return m * cosmos::smoothstep(cosmos::MOUNTAIN_C_LO, cosmos::MOUNTAIN_C_HI, c);
+}
+
+// Port of TerrainConfig._height_c (flat).
+int VoxelGeneratorCosmos::height_c(const Parameters &p, double c, double fx, double fz) {
+	const double base = cosmos::BASE_HEIGHT + cosmos::continent_offset(c);
+	const double hills = double(p.hills->get_noise_2d(fx, fz)) * cosmos::HILLS_AMPLITUDE;
+	double h = base + hills + double(p.detail->get_noise_2d(fx, fz)) * cosmos::DETAIL_AMPLITUDE;
+	const double depth = double(cosmos::SEA_LEVEL) - h;
+	const double w = cosmos::clampf(
+			cosmos::smoothstep(-cosmos::SHELF_TOP, 0.5, depth) -
+					cosmos::smoothstep(cosmos::SHELF_DEPTH - 1.5, cosmos::SHELF_DEPTH, depth),
+			0.0, 1.0);
+	if (w > 0.0) {
+		h = cosmos::lerp(h, base + hills * cosmos::SHELF_HILLS_KEEP, w);
+	}
+	h += mountain_factor(p, c, fx, fz) * cosmos::MOUNTAIN_AMPLITUDE;
+	return int(Math::floor(h));
+}
+
+// Port of TerrainConfig._height_c3 (sphere). Same spline/shelf shaping, 3D noise, and the mountain
+// factor arrives PRECOMPUTED (the GDScript signature takes `mtn`) rather than being re-sampled.
+int VoxelGeneratorCosmos::height_c3(
+		const Parameters &p, double c, double px, double py, double pz, double mtn) {
+	const double base = cosmos::BASE_HEIGHT + cosmos::continent_offset(c);
+	const double hills = double(p.hills->get_noise_3d(px, py, pz)) * cosmos::HILLS_AMPLITUDE;
+	double h = base + hills + double(p.detail->get_noise_3d(px, py, pz)) * cosmos::DETAIL_AMPLITUDE;
+	const double depth = double(cosmos::SEA_LEVEL) - h;
+	const double w = cosmos::clampf(
+			cosmos::smoothstep(-cosmos::SHELF_TOP, 0.5, depth) -
+					cosmos::smoothstep(cosmos::SHELF_DEPTH - 1.5, cosmos::SHELF_DEPTH, depth),
+			0.0, 1.0);
+	if (w > 0.0) {
+		h = cosmos::lerp(h, base + hills * cosmos::SHELF_HILLS_KEEP, w);
+	}
+	h += mtn * cosmos::MOUNTAIN_AMPLITUDE;
+	return int(Math::floor(h));
+}
+
+// Port of TerrainConfig.profile_at_dir -- THE direction-parameterised sphere-terrain profile that
+// both the curved lattice and the faceted path sample, which is why a facet shows the same planet
+// as the lattice would. Returns Vector4(g, biome, c, t); the real_t narrowing of c/t IS the
+// semantics (see cosmos_terrain.h trap 2).
+Vector4 VoxelGeneratorCosmos::profile_at_dir(
+		const Parameters &p, double dx, double dy, double dz, double rr) {
+	const double px = dx * rr;
+	const double py = dy * rr;
+	const double pz = dz * rr;
+	const double c = double(p.continent->get_noise_3d(px, py, pz));
+	const double t = cosmos::latitude_temperature(dz, double(p.temperature->get_noise_3d(px, py, pz)));
+	const double hh = double(p.humidity->get_noise_3d(px, py, pz));
+	const double mtn = mountain_factor3(p, c, px, py, pz);
+	const int g = height_c3(p, c, px, py, pz, mtn);
+	return Vector4(float(g), float(cosmos::biome_of(c, t, hh, g, mtn)), float(c), float(t));
+}
+
+// THE column profile. Ports TerrainConfig.column_profile's worker-path branches:
+//   faceted -> facet_profile(facet, x, z) -> profile_at_dir at the facet cell's true direction
+//   flat    -> the 2D noise stack
+// The pcache memo is deliberately absent: it is a pure-function cache, so omitting it cannot change
+// a value -- only cost. (The GDScript memo exists because interpreted noise calls are expensive;
+// that is the whole reason this file exists.)
+//
+// NOT PORTED, and this is a real limit to state plainly: the non-faceted CURVED branch
+// (`elif not FLAT_WORLD: _curved_profile`) with its LatticeNav edge folding and the M5C pillar
+// override. The shipped build is faceted-or-flat (FLAT_WORLD stays true), so that branch is
+// unreachable today; setup() REFUSES a config that would need it rather than silently generating a
+// different planet.
+Vector4 VoxelGeneratorCosmos::column_profile_core(const Parameters &p, int fid, int x, int z) {
+	if (p.faceted) {
+		double dx, dy, dz;
+		cell_dir(p, fid, x, z, dx, dy, dz);
+		return profile_at_dir(p, dx, dy, dz, p.facet_r_blocks);
+	}
+	const double fx = double(x);
+	const double fz = double(z);
+	const double c = double(p.continent->get_noise_2d(fx, fz));
+	const double t = double(p.temperature->get_noise_2d(fx, fz));
+	const double hh = double(p.humidity->get_noise_2d(fx, fz));
+	const int g = height_c(p, c, fx, fz);
+	const double mtn = mountain_factor(p, c, fx, fz);
+	return Vector4(float(g), float(cosmos::biome_of(c, t, hh, g, mtn)), float(c), float(t));
+}
+
+// TerrainConfig._col_h on the worker path (pcache non-null) == int(column_profile(...).x).
+int VoxelGeneratorCosmos::col_h(const Parameters &p, int fid, int x, int z) {
+	return int(column_profile_core(p, fid, x, z).x);
+}
+
+// --- TreeGen -----------------------------------------------------------------------------------
+// slope firing consults the tree stencil (a tree keeps its column's top FULL), so the slope port
+// drags TreeGen in with it. Ports tree_gen.gd:62-171.
+
+void VoxelGeneratorCosmos::tree_base_pos(int gx, int gz, int &out_bx, int &out_bz) {
+	out_bx = gx * cosmos::TREE_G + 2 + int(cosmos::tree_hash01(gx, gz, 33) * double(cosmos::TREE_G - 4));
+	out_bz = gz * cosmos::TREE_G + 2 + int(cosmos::tree_hash01(gx, gz, 44) * double(cosmos::TREE_G - 4));
+}
+
+int VoxelGeneratorCosmos::tree_species_for(int biome, int gx, int gz) {
+	switch (biome) {
+		case cosmos::B_FOREST:
+			return cosmos::tree_hash01(gx, gz, 88) < 0.70 ? cosmos::SP_OAK : cosmos::SP_BIRCH;
+		case cosmos::B_TAIGA:
+		case cosmos::B_SNOWY:
+			return cosmos::SP_SPRUCE;
+		case cosmos::B_SWAMP:
+		case cosmos::B_PLAINS:
+			return cosmos::SP_OAK;
+		default:
+			return cosmos::SP_NONE;
+	}
+}
+
+bool VoxelGeneratorCosmos::tree_has_tree(const Parameters &p, int fid, int gx, int gz) {
+	// floori(float(gx) / float(P)) -- float division then floor, NOT integer division: they differ
+	// for negative gx (integer division truncates toward zero), i.e. across half the world.
+	const int px = int(cosmos::floori(double(gx) / double(cosmos::TREE_P)));
+	const int pz = int(cosmos::floori(double(gz) / double(cosmos::TREE_P)));
+	if (cosmos::tree_hash01(px, pz, 11) >= cosmos::PATCH_CHANCE) {
+		return false;
+	}
+	if (cosmos::tree_hash01(gx, gz, 22) >= cosmos::TREE_CHANCE) {
+		return false;
+	}
+	int bx, bz;
+	tree_base_pos(gx, gz, bx, bz);
+	const int biome = int(column_profile_core(p, fid, bx, bz).y);
+	return tree_species_for(biome, gx, gz) != cosmos::SP_NONE;
+}
+
+int VoxelGeneratorCosmos::tree_oak_block(
+		int gx, int gz, int dx, int y, int dz, int gy, int log_id, int leaf_id) {
+	const int t = cosmos::TRUNK_MIN + int(cosmos::tree_hash01(gx, gz, 55) * 3.0);
+	if (dx == 0 && dz == 0) {
+		if (y >= gy + 1 && y <= gy + t) {
+			return log_id;
+		}
+		// Falls through: above the trunk the centre column can still be a cap leaf.
+	}
+	if (y == gy + t - 1 || y == gy + t) {
+		if (Math::abs(dx) <= 1 && Math::abs(dz) <= 1 && !(dx == 0 && dz == 0)) {
+			return leaf_id;
+		}
+	}
+	if (y == gy + t + 1 && Math::abs(dx) + Math::abs(dz) <= 1) {
+		return leaf_id;
+	}
+	return cosmos::ID_AIR;
+}
+
+int VoxelGeneratorCosmos::tree_spruce_block(const Parameters &p, int gx, int gz, int dx, int y, int dz, int gy) {
+	const int t = cosmos::SPRUCE_TRUNK_MIN +
+			int(cosmos::tree_hash01(gx, gz, 66) *
+					double(cosmos::SPRUCE_TRUNK_MAX - cosmos::SPRUCE_TRUNK_MIN + 1));
+	const int top = gy + t;
+	if (dx == 0 && dz == 0 && y >= gy + 1 && y <= top) {
+		return p.id_spruce_log;
+	}
+	if (y == top + 1) {
+		return (dx == 0 && dz == 0) ? p.id_spruce_leaf : cosmos::ID_AIR;
+	}
+	if (y == top || y == top - 1) {
+		if (Math::abs(dx) <= 1 && Math::abs(dz) <= 1 && !(dx == 0 && dz == 0)) {
+			return p.id_spruce_leaf;
+		}
+		return cosmos::ID_AIR;
+	}
+	if (y == top - 2 || y == top - 3) {
+		if (Math::abs(dx) + Math::abs(dz) <= 2 && !(dx == 0 && dz == 0)) {
+			return p.id_spruce_leaf;
+		}
+	}
+	return cosmos::ID_AIR;
+}
+
+int VoxelGeneratorCosmos::tree_block_at(const Parameters &p, int fid, int x, int y, int z) {
+	const int gx = int(cosmos::floori(double(x) / double(cosmos::TREE_G)));
+	const int gz = int(cosmos::floori(double(z) / double(cosmos::TREE_G)));
+	if (!tree_has_tree(p, fid, gx, gz)) {
+		return cosmos::ID_AIR;
+	}
+	int bx, bz;
+	tree_base_pos(gx, gz, bx, bz);
+	const int gy = col_h(p, fid, bx, bz);
+	if (gy <= cosmos::SEA_LEVEL) {
+		return cosmos::ID_AIR; // no submerged half-trees
+	}
+	const int species = tree_species_for(int(column_profile_core(p, fid, bx, bz).y), gx, gz);
+	const int dx = x - bx;
+	const int dz = z - bz;
+	switch (species) {
+		case cosmos::SP_OAK:
+			return tree_oak_block(gx, gz, dx, y, dz, gy, p.id_wood, p.id_leaf);
+		case cosmos::SP_BIRCH:
+			return tree_oak_block(gx, gz, dx, y, dz, gy, p.id_birch_log, p.id_birch_leaf);
+		case cosmos::SP_SPRUCE:
+			return tree_spruce_block(p, gx, gz, dx, y, dz, gy);
+		default:
+			return cosmos::ID_AIR;
+	}
+}
+
+// --- SHARP-SLOPE -------------------------------------------------------------------------------
+// Port of TerrainConfig._corner_targets. Vector4 (real_t) return is the GDScript type and its f32
+// rounding is load-bearing: _slope_fires_only reads these back and rounds them on a quarter grid.
+Vector4 VoxelGeneratorCosmos::corner_targets(const Parameters &p, int fid, int x, int z) {
+	const double t_nn = double(col_h(p, fid, x - 1, z - 1) + 1);
+	const double t_0n = double(col_h(p, fid, x, z - 1) + 1);
+	const double t_pn = double(col_h(p, fid, x + 1, z - 1) + 1);
+	const double t_n0 = double(col_h(p, fid, x - 1, z) + 1);
+	const double t_00 = double(col_h(p, fid, x, z) + 1);
+	const double t_p0 = double(col_h(p, fid, x + 1, z) + 1);
+	const double t_np = double(col_h(p, fid, x - 1, z + 1) + 1);
+	const double t_0p = double(col_h(p, fid, x, z + 1) + 1);
+	const double t_pp = double(col_h(p, fid, x + 1, z + 1) + 1);
+	return Vector4(
+			float((t_nn + t_0n + t_n0 + t_00) * 0.25),
+			float((t_0n + t_pn + t_00 + t_p0) * 0.25),
+			float((t_00 + t_p0 + t_0p + t_pp) * 0.25),
+			float((t_n0 + t_00 + t_np + t_0p) * 0.25));
+}
+
+// Port of TerrainConfig._slope_fires_only.
+bool VoxelGeneratorCosmos::slope_fires_only(const Parameters &p, int fid, int x, int z, int g) {
+	if (!cosmos::SMOOTHING_ENABLED || g < cosmos::SEA_LEVEL) {
+		return false; // v1: land only
+	}
+	// _is_pillar_column: M5C_CORNER-gated, and short-circuits BEFORE the profile read when off.
+	if (p.m5c_corner && int(column_profile_core(p, fid, x, z).y) == cosmos::B_PILLAR) {
+		return false;
+	}
+	if (tree_block_at(p, fid, x, g + 1, z) != cosmos::ID_AIR) {
+		return false; // a tree rests here -> keep the top FULL
+	}
+	const Vector4 raw = corner_targets(p, fid, x, z);
+	// Integer quarter-units (float-robust), exactly as the GDScript does it.
+	const int64_t r0 = cosmos::roundi(double(raw.x) * 4.0);
+	const int64_t r1 = cosmos::roundi(double(raw.y) * 4.0);
+	const int64_t r2 = cosmos::roundi(double(raw.z) * 4.0);
+	const int64_t r3 = cosmos::roundi(double(raw.w) * 4.0);
+	const int64_t lo_r = MIN(MIN(r0, r1), MIN(r2, r3));
+	const int64_t hi_r = MAX(MAX(r0, r1), MAX(r2, r3));
+	if (lo_r >= int64_t(g) * 4 && hi_r <= int64_t(g + 2) * 4) {
+		if (lo_r >= int64_t(g) * 4 && hi_r <= int64_t(g + 1) * 4) {
+			return false; // within [g, g+1] -> today's smoothing, all biomes
+		}
+		if (int(column_profile_core(p, fid, x, z).y) != cosmos::B_MOUNTAINS) {
+			return false; // the 1-2 block/cell band off the mountains -> leave hills alone
+		}
+	}
+	const int64_t tw0 = cosmos::roundi(double(raw.x));
+	const int64_t tw1 = cosmos::roundi(double(raw.y));
+	const int64_t tw2 = cosmos::roundi(double(raw.z));
+	const int64_t tw3 = cosmos::roundi(double(raw.w));
+	const int64_t lo = MIN(MIN(tw0, tw1), MIN(tw2, tw3));
+	const int64_t hi = MAX(MAX(tw0, tw1), MAX(tw2, tw3));
+	if (hi - lo < 1 || hi - lo > cosmos::SLOPE_MAX_SPREAD) {
+		return false; // flat (nothing to grade) OR too steep (cliff)
+	}
+	return lo >= int64_t(g - cosmos::SLOPE_MAX_SPREAD) && hi <= int64_t(g + cosmos::SLOPE_MAX_SPREAD + 1);
+}
+
+// Port of TerrainConfig._slope_whole_targets + _slope_run_pack.
+int VoxelGeneratorCosmos::slope_run_pack(const Vector4i &tw, int g) {
+	const int c0 = CLAMP(tw.x - g + 4, 0, 15);
+	const int c1 = CLAMP(tw.y - g + 4, 0, 15);
+	const int c2 = CLAMP(tw.z - g + 4, 0, 15);
+	const int c3 = CLAMP(tw.w - g + 4, 0, 15);
+	return (1 << 16) | (c3 << 12) | (c2 << 8) | (c1 << 4) | c0;
+}
+
+// Port of TerrainConfig.slope_run_of, WORKER path (pcache non-null). The pcache == null branch reads
+// the main-thread shape memo (_shape_entry), which is not what a worker or this port does.
+int VoxelGeneratorCosmos::slope_run_core(const Parameters &p, int fid, int x, int z, int g) {
+	if (!cosmos::SMOOTHING_ENABLED) {
+		return 0;
+	}
+	if (!slope_fires_only(p, fid, x, z, g)) {
+		return 0;
+	}
+	const Vector4 raw = corner_targets(p, fid, x, z);
+	const Vector4i tw(int(cosmos::roundi(double(raw.x))), int(cosmos::roundi(double(raw.y))),
+			int(cosmos::roundi(double(raw.z))), int(cosmos::roundi(double(raw.w))));
+	return slope_run_pack(tw, g);
+}
+
+// ================================================================================================
+// S3 — resolve_cell + helpers. Line-for-line from TerrainConfig / CellCodec / ShapeCodec /
+// ClimateModel. This is where the measured 337.7 ms/block underground and 559.8 ms/block surface
+// cost lives. Same transcription discipline as S2 (cosmos_terrain.h's four traps).
+// ================================================================================================
+
+using namespace cosmos;
+
+// --- CellCodec / ShapeCodec pack path ----------------------------------------------------------
+int VoxelGeneratorCosmos::shape_make_modifier(int c00, int c10, int c11, int c01, int anc) {
+	return (c00 & 3) | ((c10 & 3) << 2) | ((c11 & 3) << 4) | ((c01 & 3) << 6) | ((anc & 1) << 8);
+}
+
+int VoxelGeneratorCosmos::cc_slope_raw(int d00, int d10, int d11, int d01) {
+	const int k00 = cosmos::clampi(d00 + MOD_SLOPE_BIAS, 0, 7);
+	const int k10 = cosmos::clampi(d10 + MOD_SLOPE_BIAS, 0, 7);
+	const int k11 = cosmos::clampi(d11 + MOD_SLOPE_BIAS, 0, 7);
+	const int k01 = cosmos::clampi(d01 + MOD_SLOPE_BIAS, 0, 7);
+	return MOD_FAM_BIT | (FAM_SLOPE << MOD_FAM_KIND_SHIFT) | (k01 << 9) | (k11 << 6) | (k10 << 3) | k00;
+}
+
+int VoxelGeneratorCosmos::cc_canonical_slope(int d00, int d10, int d11, int d01) {
+	if (d00 >= 1 && d10 >= 1 && d11 >= 1 && d01 >= 1) {
+		return 0; // rule 1: full cube
+	}
+	if (d00 <= 0 && d10 <= 0 && d11 <= 0 && d01 <= 0) {
+		return MOD_FAM_BIT; // rule 2: empty
+	}
+	if (d00 >= 0 && d00 <= 1 && d10 >= 0 && d10 <= 1 && d11 >= 0 && d11 <= 1 && d01 >= 0 && d01 <= 1) {
+		return shape_make_modifier(2 * d00, 2 * d10, 2 * d11, 2 * d01, ANCHOR_BOTTOM); // rule 3
+	}
+	return cc_slope_raw(d00, d10, d11, d01); // rule 4
+}
+
+int VoxelGeneratorCosmos::cc_make_slope(int d00, int d10, int d11, int d01) {
+	return cc_canonical_slope(d00, d10, d11, d01);
+}
+
+int VoxelGeneratorCosmos::cc_make_layer(int level) {
+	const int lv = cosmos::clampi(level, 0, 10);
+	if (lv <= 0) {
+		return MOD_FAM_BIT;
+	}
+	if (lv >= 10) {
+		return 0;
+	}
+	if (lv == 5) {
+		return LAYER_SLAB_MODIFIER;
+	}
+	return MOD_FAM_BIT | lv;
+}
+
+int64_t VoxelGeneratorCosmos::cc_pack(int mat, int modifier, int state, int liquid) {
+	return (int64_t(mat) & MAT_MASK) | ((int64_t(modifier) & 0xFFFF) << 16) |
+			((int64_t(state) & 0xFFFF) << 32) | ((int64_t(liquid) & LIQ_FIELD_MASK) << LIQ_SHIFT);
+}
+
+int VoxelGeneratorCosmos::cc_make_liquid(int kind, int level) {
+	return (kind & LIQ_KIND_MASK) | ((level & 0xF) << 2);
+}
+
+int VoxelGeneratorCosmos::cc_mat(int64_t v) {
+	return int(v & MAT_MASK);
+}
+int VoxelGeneratorCosmos::cc_modifier(int64_t v) {
+	return int((v >> 16) & 0xFFFF);
+}
+int VoxelGeneratorCosmos::cc_state(int64_t v) {
+	return int((v >> 32) & 0xFFFF);
+}
+int VoxelGeneratorCosmos::cc_liquid_field(int64_t v) {
+	return int((v >> LIQ_SHIFT) & LIQ_FIELD_MASK);
+}
+
+int64_t VoxelGeneratorCosmos::cc_with_state(int64_t v, int bits) {
+	return (v & ~(STATE_MASK << 32)) | ((int64_t(bits) & STATE_MASK) << 32);
+}
+
+int64_t VoxelGeneratorCosmos::cc_with_liquid(int64_t v, int kind, int level) {
+	const int64_t stripped = v & ~(int64_t(LIQ_FIELD_MASK) << LIQ_SHIFT);
+	return stripped | (int64_t(cc_make_liquid(kind, level)) << LIQ_SHIFT);
+}
+
+int64_t VoxelGeneratorCosmos::cc_with_snow_fill(int64_t v, int level) {
+	int st = cc_state(v) & ~STATE_SNOW_FILL_MASK;
+	st |= (cosmos::clampi(level, 0, 15) & 0xF) << STATE_SNOW_FILL_SHIFT;
+	return cc_with_state(v, st);
+}
+
+double VoxelGeneratorCosmos::solidity_of(const Parameters &p, int mat) {
+	if (mat < 0 || mat >= p.solidity.size()) {
+		return 0.0;
+	}
+	return p.solidity[mat];
+}
+
+int VoxelGeneratorCosmos::state_mask_of(const Parameters &p, int lrid) {
+	if (lrid <= ID_AIR || lrid >= p.block_count) {
+		return 0;
+	}
+	return p.state_mask[lrid];
+}
+
+int VoxelGeneratorCosmos::cc_canonical_modifier(const Parameters &p, int material, int modifier_bits) {
+	if (modifier_bits != 0 && solidity_of(p, material) < 0.5) {
+		return 0; // "ramp of water" -> full cube
+	}
+	if (modifier_bits == 0) {
+		return 0;
+	}
+	if (modifier_bits & MOD_FAM_BIT) {
+		if (modifier_bits == MOD_FAM_BIT) {
+			return MOD_FAM_BIT;
+		}
+		const int kind = (modifier_bits >> MOD_FAM_KIND_SHIFT) & MOD_FAM_KIND_MASK;
+		if (kind == FAM_LAYER) {
+			const int reserved = (modifier_bits >> 4) & 0xFF;
+			if (reserved != 0) {
+				return 0;
+			}
+			return cc_make_layer(modifier_bits & MOD_LAYER_LEVEL_MASK);
+		}
+		if (kind == FAM_SLOPE) {
+			const int d00 = (modifier_bits & 7) - MOD_SLOPE_BIAS;
+			const int d10 = ((modifier_bits >> 3) & 7) - MOD_SLOPE_BIAS;
+			const int d11 = ((modifier_bits >> 6) & 7) - MOD_SLOPE_BIAS;
+			const int d01 = ((modifier_bits >> 9) & 7) - MOD_SLOPE_BIAS;
+			return cc_canonical_slope(d00, d10, d11, d01);
+		}
+		if (kind == FAM_JUNCTION) {
+			return MOD_FAM_BIT | (FAM_JUNCTION << MOD_FAM_KIND_SHIFT) |
+					(modifier_bits & ((0x3 << 10) | (0x1F << 5)));
+		}
+		return 0;
+	}
+	const int c0 = cosmos::mini(modifier_bits & 3, 2);
+	const int c1 = cosmos::mini((modifier_bits >> 2) & 3, 2);
+	const int c2 = cosmos::mini((modifier_bits >> 4) & 3, 2);
+	const int c3 = cosmos::mini((modifier_bits >> 6) & 3, 2);
+	if (c0 == 2 && c1 == 2 && c2 == 2 && c3 == 2) {
+		return 0;
+	}
+	const int anc = modifier_bits & MOD_ANC_BIT;
+	return c0 | (c1 << 2) | (c2 << 4) | (c3 << 6) | anc;
+}
+
+int VoxelGeneratorCosmos::cc_validate_state(const Parameters &p, int material, int state_bits) {
+	if (state_bits == 0) {
+		return 0;
+	}
+	return state_bits & state_mask_of(p, material);
+}
+
+int VoxelGeneratorCosmos::cc_canonical_snow_fill(
+		const Parameters &p, int material, int canonical_mod, int state_bits) {
+	const int fill = (state_bits >> STATE_SNOW_FILL_SHIFT) & 0xF;
+	if (fill == 0) {
+		return state_bits;
+	}
+	const int stripped = state_bits & ~STATE_SNOW_FILL_MASK;
+	if (solidity_of(p, material) < 0.5) {
+		return stripped;
+	}
+	if (canonical_mod == 0) {
+		return stripped;
+	}
+	if ((canonical_mod & MOD_FAM_BIT) != 0) {
+		return stripped;
+	}
+	const int min_corner = cosmos::mini(cosmos::mini(canonical_mod & 3, (canonical_mod >> 2) & 3),
+			cosmos::mini((canonical_mod >> 4) & 3, (canonical_mod >> 6) & 3));
+	if (fill <= 5 * min_corner) {
+		return stripped;
+	}
+	if (fill > 10) {
+		return (state_bits & ~STATE_SNOW_FILL_MASK) | (10 << STATE_SNOW_FILL_SHIFT);
+	}
+	return state_bits;
+}
+
+int VoxelGeneratorCosmos::cc_canonical_liquid(
+		const Parameters &p, int material, int canonical_mod, int liquid) {
+	if (liquid == 0) {
+		return 0;
+	}
+	const int kind = liquid & LIQ_KIND_MASK;
+	int level = (liquid >> 2) & 0xF;
+	if (kind == 0) {
+		return 0;
+	}
+	if (level == 0) {
+		return 0;
+	}
+	if (level > LIQ_LEVEL_FULL) {
+		level = LIQ_LEVEL_FULL;
+	}
+	if (solidity_of(p, material) < 0.5) {
+		// Rule 5: non-solid host. kind must match the material's own liquid identity.
+		int host_kind = 0;
+		if (material == p.liquid_lrid_water) {
+			host_kind = LIQ_WATER;
+		} else if (material == p.liquid_lrid_lava) {
+			host_kind = LIQ_LAVA;
+		}
+		if (kind != host_kind) {
+			return 0;
+		}
+		if (level == LIQ_LEVEL_FULL) {
+			return 0;
+		}
+		return cc_make_liquid(kind, level);
+	}
+	if (canonical_mod == 0) {
+		return 0; // rule 6: no remainder
+	}
+	// is_liquid_kind_known: water/lava registered iff their lrid resolved.
+	const bool known = (kind == LIQ_WATER && p.liquid_lrid_water >= 0) ||
+			(kind == LIQ_LAVA && p.liquid_lrid_lava >= 0);
+	if (!known) {
+		return 0;
+	}
+	return cc_make_liquid(kind, level);
+}
+
+int64_t VoxelGeneratorCosmos::cc_canonical(const Parameters &p, int64_t v) {
+	const int m = cc_mat(v);
+	if (m == ID_AIR) {
+		return 0;
+	}
+	const int cm = cc_canonical_modifier(p, m, cc_modifier(v));
+	if (cm == MOD_FAM_BIT) {
+		return 0;
+	}
+	if (cm != 0 && (cm & MOD_FAM_BIT) == 0 && (cm & MOD_CORNERS_MASK) == 0) {
+		return 0;
+	}
+	const int st = cc_canonical_snow_fill(p, m, cm, cc_validate_state(p, m, cc_state(v)));
+	const int lq = cc_canonical_liquid(p, m, cm, cc_liquid_field(v));
+	return cc_pack(m, cm, st, lq);
+}
+
+// --- resolve_cell helper chain -----------------------------------------------------------------
+
+bool VoxelGeneratorCosmos::bedrock_at(const Parameters &p, int x, int y, int z) {
+	if (y <= WORLD_BOTTOM_Y) {
+		return true;
+	}
+	if (y >= BEDROCK_TOP_Y) {
+		return false;
+	}
+	const double pr = double(BEDROCK_TOP_Y - y) / double(BEDROCK_TOP_Y - WORLD_BOTTOM_Y);
+	return hash01_3d(x, y, z, SALT_BEDROCK) < pr;
+}
+
+int VoxelGeneratorCosmos::sea_liquid_kind(double t) {
+	return t >= LAVA_SEA_T ? LIQ_LAVA : LIQ_WATER;
+}
+
+int64_t VoxelGeneratorCosmos::sea_block(const Parameters &p, double t, int y) {
+	const int kind = sea_liquid_kind(t);
+	const int lrid = (kind == LIQ_LAVA) ? p.liquid_lrid_lava : p.liquid_lrid_water;
+	if (y == SEA_LEVEL) {
+		if (t < -0.55) {
+			return p.id_ice;
+		}
+		return cc_pack(lrid, 0, 0, cc_make_liquid(kind, LIQ_LEVEL_SURFACE));
+	}
+	return lrid;
+}
+
+int VoxelGeneratorCosmos::biome_top(const Parameters &p, int biome, int x, int z) {
+	switch (biome) {
+		case B_BEACH:
+		case B_DESERT:
+			return p.id_sand;
+		case B_BADLANDS:
+			return p.id_red_sand;
+		case B_SWAMP:
+			return p.id_mud;
+		case B_SNOWY:
+			return p.id_snow;
+		case B_TAIGA:
+			return hash01_3d(x, 0, z, SALT_PODZOL) < 0.20 ? p.id_podzol : p.id_grass;
+		case B_MOUNTAINS:
+			return p.id_stone;
+		case B_OCEAN:
+			return p.id_sand;
+		default:
+			return p.id_grass;
+	}
+}
+
+int VoxelGeneratorCosmos::underwater_floor(const Parameters &p, int biome, int x, int z, double t) {
+	switch (biome) {
+		case B_OCEAN:
+			return t > 0.0 ? p.id_sand : p.id_gravel;
+		case B_BEACH:
+		case B_DESERT:
+			return p.id_sand;
+		case B_BADLANDS:
+			return p.id_red_sand;
+		case B_SWAMP:
+			return p.id_mud;
+		default:
+			return p.id_gravel;
+	}
+}
+
+int VoxelGeneratorCosmos::filler_depth(int biome) {
+	switch (biome) {
+		case B_BADLANDS:
+			return 12;
+		case B_DESERT:
+			return 7;
+		case B_BEACH:
+			return 6;
+		case B_SWAMP:
+			return 5;
+		case B_OCEAN:
+			return 3;
+		case B_MOUNTAINS:
+			return 0;
+		default:
+			return 3;
+	}
+}
+
+int VoxelGeneratorCosmos::band_color(const Parameters &p, int x, int y, int z) {
+	const int shift = int(hash01_3d(cosmos::floori(x / 512.0), 0, cosmos::floori(z / 512.0), SALT_BAND) * 7.0);
+	const int n = p.band_seq.size();
+	return p.band_seq[int(cosmos::posmod(int64_t(y) + shift, n))];
+}
+
+int VoxelGeneratorCosmos::biome_filler(
+		const Parameters &p, int biome, int x, int y, int z, int depth, double t) {
+	switch (biome) {
+		case B_BEACH:
+		case B_DESERT:
+			return depth <= 3 ? p.id_sand : p.id_sandstone;
+		case B_BADLANDS:
+			return depth <= 8 ? band_color(p, x, y, z) : p.id_red_sandstone;
+		case B_SWAMP:
+			return depth <= 3 ? p.id_mud : p.id_dirt;
+		case B_OCEAN:
+			return underwater_floor(p, B_OCEAN, x, z, t);
+		default:
+			return p.id_dirt;
+	}
+}
+
+int VoxelGeneratorCosmos::surface_rule(
+		const Parameters &p, int x, int y, int z, int g, int biome, double c, double t) {
+	const bool underwater = g < SEA_LEVEL;
+	if (y == g) {
+		if (underwater) {
+			return underwater_floor(p, biome, x, z, t);
+		}
+		return biome_top(p, biome, x, z);
+	}
+	const int depth = g - y;
+	if (depth <= filler_depth(biome)) {
+		return biome_filler(p, biome, x, y, z, depth, t);
+	}
+	return p.id_stone;
+}
+
+int VoxelGeneratorCosmos::strata_variant_of(const Parameters &p, int lx, int ly, int lz, int cy) {
+	if (cy < -32) {
+		const double d = hash01_3d(lx, ly, lz, SALT_STRATA_VAR + 1);
+		if (d < 0.10) {
+			return p.id_sulfur;
+		}
+		if (d < 0.20) {
+			return p.id_cinnabar;
+		}
+	}
+	const double h = hash01_3d(lx, ly, lz, SALT_STRATA_VAR);
+	const int n = p.strata_seq.size();
+	return p.strata_seq[int(h * double(n)) % n];
+}
+
+int VoxelGeneratorCosmos::strata_at(const Parameters &p, int x, int y, int z) {
+	const int lx = int(cosmos::floori(x / double(STRATA_L)));
+	const int ly = int(cosmos::floori(y / double(STRATA_L)));
+	const int lz = int(cosmos::floori(z / double(STRATA_L)));
+	if (hash01_3d(lx, ly, lz, SALT_STRATA_EXIST) >= 0.25) {
+		return -1;
+	}
+	const int r = 3 + int(hash01_3d(lx, ly, lz, SALT_STRATA_R) * 5.0);
+	const int span = cosmos::maxi(STRATA_L - 2 * r, 0);
+	const int bx = lx * STRATA_L + r + int(hash01_3d(lx, ly, lz, SALT_STRATA_JX) * double(span + 1));
+	const int by = ly * STRATA_L + r + int(hash01_3d(lx, ly, lz, SALT_STRATA_JY) * double(span + 1));
+	const int bz = lz * STRATA_L + r + int(hash01_3d(lx, ly, lz, SALT_STRATA_JZ) * double(span + 1));
+	const int dx = x - bx, dy = y - by, dz = z - bz;
+	if (dx * dx + dy * dy + dz * dz > r * r) {
+		return -1;
+	}
+	return strata_variant_of(p, lx, ly, lz, by);
+}
+
+int VoxelGeneratorCosmos::deep_family(const Parameters &p, int x, int y, int z) {
+	int base = p.id_stone;
+	if (y < DEEPSLATE_FULL_Y) {
+		base = p.id_deepslate;
+	} else if (y <= DEEPSLATE_TOP_Y) {
+		const int band = DEEPSLATE_TOP_Y - DEEPSLATE_FULL_Y; // 8
+		if (hash01_3d(x, y, z, SALT_DEEP) < double(DEEPSLATE_TOP_Y - y) / double(band)) {
+			base = p.id_deepslate;
+		}
+	}
+	const int variant = strata_at(p, x, y, z);
+	if (variant >= 0) {
+		if (base == p.id_stone) {
+			return variant;
+		}
+		if (variant == p.id_sulfur || variant == p.id_cinnabar) {
+			return variant;
+		}
+	}
+	return base;
+}
+
+double VoxelGeneratorCosmos::ore_density(int i, int y) {
+	const int ymin = ORE_YMIN[i], ymax = ORE_YMAX[i], peak = ORE_PEAK[i];
+	if (y < ymin || y > ymax) {
+		return 0.0;
+	}
+	if (y <= peak) {
+		return peak == ymin ? 1.0 : double(y - ymin) / double(peak - ymin);
+	}
+	return ymax == peak ? 1.0 : double(ymax - y) / double(ymax - peak);
+}
+
+double VoxelGeneratorCosmos::eff_weight(int i, int y, int biome, double c) {
+	if (i == ORE_EMERALD && c <= 0.4) {
+		return 0.0;
+	}
+	double w = ORE_WEIGHT[i] * ore_density(i, y);
+	if (i == ORE_GOLD && biome == B_BADLANDS) {
+		w *= 4.0;
+	}
+	return w;
+}
+
+int VoxelGeneratorCosmos::pick_ore(const Parameters &p, int y, int biome, double c, int lx, int ly, int lz) {
+	double total = 0.0;
+	for (int i = 0; i < 8; ++i) {
+		total += eff_weight(i, y, biome, c);
+	}
+	if (total <= 0.0) {
+		return -1;
+	}
+	const double r = hash01_3d(lx, ly, lz, SALT_ORE_PICK) * total;
+	double acc = 0.0;
+	for (int i = 0; i < 8; ++i) {
+		acc += eff_weight(i, y, biome, c);
+		if (r < acc) {
+			return i;
+		}
+	}
+	return 7;
+}
+
+int VoxelGeneratorCosmos::ore_apply(const Parameters &p, int ore, int y, int host) {
+	if (ore < 0 || ore_density(ore, y) <= 0.0) {
+		return host;
+	}
+	return host == p.id_deepslate ? p.ore_deep[ore] : p.ore_stone[ore];
+}
+
+int VoxelGeneratorCosmos::ore_at(const Parameters &p, int x, int y, int z, int host, int biome, double c) {
+	if (host != p.id_stone && host != p.id_deepslate) {
+		return host;
+	}
+	const int lx = int(cosmos::floori(x / double(ORE_L)));
+	const int ly = int(cosmos::floori(y / double(ORE_L)));
+	const int lz = int(cosmos::floori(z / double(ORE_L)));
+	if (hash01_3d(lx, ly, lz, SALT_ORE_EXIST) >= 0.55) {
+		return host;
+	}
+	const int r = 1 + int(hash01_3d(lx, ly, lz, SALT_ORE_R) * 2.0);
+	const int span = cosmos::maxi(ORE_L - 2 * r, 0);
+	const int bx = lx * ORE_L + r + int(hash01_3d(lx, ly, lz, SALT_ORE_JX) * double(span + 1));
+	const int by = ly * ORE_L + r + int(hash01_3d(lx, ly, lz, SALT_ORE_JY) * double(span + 1));
+	const int bz = lz * ORE_L + r + int(hash01_3d(lx, ly, lz, SALT_ORE_JZ) * double(span + 1));
+	const int dx = x - bx, dy = y - by, dz = z - bz;
+	if (dx * dx + dy * dy + dz * dz > r * r) {
+		return host;
+	}
+	return ore_apply(p, pick_ore(p, by, biome, c, lx, ly, lz), y, host);
+}
+
+// --- ClimateModel + snow -----------------------------------------------------------------------
+
+double VoxelGeneratorCosmos::climate_base(double t) {
+	if (t >= CLIMATE_TEMPERATE) {
+		return T_SEA_LEVEL;
+	}
+	if (t < CLIMATE_FROZEN) {
+		return T_FROZEN_SEA;
+	}
+	return cosmos::lerp(T_FROZEN_SEA, T_SEA_LEVEL, (t - CLIMATE_FROZEN) / (CLIMATE_TEMPERATE - CLIMATE_FROZEN));
+}
+
+double VoxelGeneratorCosmos::surface_temperature(int surface_y, double t) {
+	return climate_base(t) - LAPSE_RATE * MAX(double(surface_y), 0.0);
+}
+
+double VoxelGeneratorCosmos::h_ref(const Parameters &p, int fid, int x, int z) {
+	const int l = SNOW_REF_LATTICE;
+	const int x0 = int(cosmos::floori(x / double(l))) * l;
+	const int z0 = int(cosmos::floori(z / double(l))) * l;
+	const int x1 = x0 + l;
+	const int z1 = z0 + l;
+	const double h00 = double(col_h(p, fid, x0, z0));
+	const double h10 = double(col_h(p, fid, x1, z0));
+	const double h01 = double(col_h(p, fid, x0, z1));
+	const double h11 = double(col_h(p, fid, x1, z1));
+	const double tx = double(x - x0) / double(l);
+	const double tz = double(z - z0) / double(l);
+	return cosmos::lerp(cosmos::lerp(h00, h10, tx), cosmos::lerp(h01, h11, tx), tz);
+}
+
+int VoxelGeneratorCosmos::snow_depth(const Parameters &p, int fid, int x, int z, int g, double t) {
+	if (g < SEA_LEVEL) {
+		return 0;
+	}
+	const double ts = surface_temperature(g, t);
+	if (ts >= SNOW_T0) {
+		return 0;
+	}
+	if (tree_block_at(p, fid, x, g + 1, z) != ID_AIR) {
+		return 0;
+	}
+	const double neg = -ts;
+	const int d_blanket = cosmos::clampi(int(cosmos::roundi(SNOW_BLANKET_PER_C * neg)), 0, SNOW_BLANKET_MAX);
+	const double pp = h_ref(p, fid, x, z) + 1.0 +
+			MIN(SNOW_FILL_PER_C * neg, 10.0 * double(SNOW_FILL_MAX_CELLS)) / 10.0;
+	const double fill_blocks = cosmos::clampf(pp - double(g + 1), 0.0, double(SNOW_FILL_MAX_CELLS));
+	const int d_fill = int(cosmos::roundi(fill_blocks * 10.0));
+	return cosmos::maxi(d_blanket, d_fill);
+}
+
+int64_t VoxelGeneratorCosmos::snow_stack(const Parameters &p, int fid, int x, int y, int z, int g, double t) {
+	const int d = snow_depth(p, fid, x, z, g, t);
+	if (d <= 0) {
+		return ID_AIR;
+	}
+	const int remaining = d - (y - (g + 1)) * 10;
+	if (remaining <= 0) {
+		return ID_AIR;
+	}
+	if (remaining >= 10) {
+		return cc_pack(p.id_snow, 0, 0, 0);
+	}
+	return cc_pack(p.id_snow, cc_make_layer(remaining), 0, 0);
+}
+
+// --- smoothing / cap ---------------------------------------------------------------------------
+
+int VoxelGeneratorCosmos::modifier_from_targets(const Vector4 &targets, int base_y) {
+	const double by = double(base_y);
+	const int c00 = cosmos::clampi(int(cosmos::roundi((double(targets.x) - by) * 2.0)), 0, 2);
+	const int c10 = cosmos::clampi(int(cosmos::roundi((double(targets.y) - by) * 2.0)), 0, 2);
+	const int c11 = cosmos::clampi(int(cosmos::roundi((double(targets.z) - by) * 2.0)), 0, 2);
+	const int c01 = cosmos::clampi(int(cosmos::roundi((double(targets.w) - by) * 2.0)), 0, 2);
+	if (c00 == 2 && c10 == 2 && c11 == 2 && c01 == 2) {
+		return 0;
+	}
+	if (c00 == 0 && c10 == 0 && c11 == 0 && c01 == 0) {
+		return 0;
+	}
+	return shape_make_modifier(c00, c10, c11, c01, ANCHOR_BOTTOM);
+}
+
+bool VoxelGeneratorCosmos::col_fires(const Parameters &p, int fid, int X, int Z) {
+	return slope_fires_only(p, fid, X, Z, col_h(p, fid, X, Z));
+}
+
+double VoxelGeneratorCosmos::q_target(double raw_t, bool whole) {
+	if (whole) {
+		return double(cosmos::roundi(raw_t));
+	}
+	return cosmos::roundf_gd(raw_t * 2.0) / 2.0;
+}
+
+Vector4 VoxelGeneratorCosmos::quantized_targets(const Parameters &p, int fid, int x, int z) {
+	const Vector4 raw = corner_targets(p, fid, x, z);
+	const bool f[9] = {
+		col_fires(p, fid, x - 1, z - 1), col_fires(p, fid, x - 1, z), col_fires(p, fid, x - 1, z + 1),
+		col_fires(p, fid, x, z - 1), col_fires(p, fid, x, z), col_fires(p, fid, x, z + 1),
+		col_fires(p, fid, x + 1, z - 1), col_fires(p, fid, x + 1, z), col_fires(p, fid, x + 1, z + 1)
+	};
+	const bool w00 = f[0] || f[3] || f[1] || f[4];
+	const bool w10 = f[3] || f[6] || f[4] || f[7];
+	const bool w11 = f[4] || f[7] || f[5] || f[8];
+	const bool w01 = f[1] || f[4] || f[2] || f[5];
+	return Vector4(float(q_target(double(raw.x), w00)), float(q_target(double(raw.y), w10)),
+			float(q_target(double(raw.z), w11)), float(q_target(double(raw.w), w01)));
+}
+
+int VoxelGeneratorCosmos::cap_material(const Parameters &p, int biome, int x, int z, double t, int g) {
+	return g >= SEA_LEVEL ? biome_top(p, biome, x, z) : underwater_floor(p, biome, x, z, t);
+}
+
+int64_t VoxelGeneratorCosmos::surface_cap(
+		const Parameters &p, int fid, int x, int z, int g, int biome, double t) {
+	if (!SMOOTHING_ENABLED) {
+		return ID_AIR;
+	}
+	if (tree_block_at(p, fid, x, g + 1, z) != ID_AIR) {
+		return ID_AIR;
+	}
+	const int m = modifier_from_targets(quantized_targets(p, fid, x, z), g + 1);
+	if (m == 0) {
+		return ID_AIR;
+	}
+	return cc_pack(cap_material(p, biome, x, z, t, g), m, 0, 0);
+}
+
+int64_t VoxelGeneratorCosmos::smoothed_surface(const Parameters &p, int fid, int x, int z, int g, int mat) {
+	if (!SMOOTHING_ENABLED) {
+		return mat;
+	}
+	if (tree_block_at(p, fid, x, g + 1, z) != ID_AIR) {
+		return mat;
+	}
+	const int m = modifier_from_targets(quantized_targets(p, fid, x, z), g);
+	if (m == 0) {
+		return mat;
+	}
+	return cc_pack(mat, m, 0, 0);
+}
+
+// --- state/liquid/snow composition wrappers ----------------------------------------------------
+
+int64_t VoxelGeneratorCosmos::with_shore_liquid(const Parameters &p, int64_t v, int y, double t) {
+	if (y > SEA_LEVEL || cc_modifier(v) == 0) {
+		return v;
+	}
+	if (y == SEA_LEVEL && t < -0.55) {
+		return v;
+	}
+	const int lvl = (y == SEA_LEVEL) ? LIQ_LEVEL_SURFACE : LIQ_LEVEL_FULL;
+	return cc_with_liquid(v, sea_liquid_kind(t), lvl);
+}
+
+int64_t VoxelGeneratorCosmos::with_snow_state(const Parameters &p, int fid, int64_t v, int g, double t) {
+	if (g < SEA_LEVEL) {
+		return v;
+	}
+	if (cc_liquid_field(v) != 0) {
+		return v;
+	}
+	const int mat = cc_mat(v);
+	if ((state_mask_of(p, mat) & STATE_SNOW_CAPPED) == 0) {
+		return v;
+	}
+	if (surface_temperature(g, t) >= 0.0) {
+		return v;
+	}
+	return cc_with_state(v, cc_state(v) | STATE_SNOW_CAPPED);
+}
+
+int64_t VoxelGeneratorCosmos::with_surface_snow_fill(
+		const Parameters &p, int fid, int64_t v, int x, int z, int g, double t) {
+	if (cc_modifier(v) == 0) {
+		return v;
+	}
+	if (snow_depth(p, fid, x, z, g, t) <= 0) {
+		return v;
+	}
+	return cc_canonical(p, cc_with_snow_fill(v, 10));
+}
+
+int64_t VoxelGeneratorCosmos::with_lip_snow_fill(
+		const Parameters &p, int fid, int64_t v, int x, int z, int g, double t) {
+	if (cc_modifier(v) == 0) {
+		return v;
+	}
+	const int d = snow_depth(p, fid, x, z, g, t);
+	if (d <= 0) {
+		return v;
+	}
+	return cc_canonical(p, cc_with_snow_fill(v, cosmos::mini(d, 10)));
+}
+
+Vector4i VoxelGeneratorCosmos::slope_run_targets(int r, int g) {
+	return Vector4i((r & 15) - 4 + g, ((r >> 4) & 15) - 4 + g, ((r >> 8) & 15) - 4 + g,
+			((r >> 12) & 15) - 4 + g);
+}
+
+// --- THE cell resolver -------------------------------------------------------------------------
+// Port of TerrainConfig.resolve_cell (the worker path: slope_run passed in, pcache non-null).
+int64_t VoxelGeneratorCosmos::resolve_cell_core(
+		const Parameters &p, int fid, int x, int y, int z, const Vector4 &prof, int slope_run) {
+	const int g = int(prof.x);
+	const int biome = int(prof.y);
+	const double c = double(prof.z);
+	const double t = double(prof.w);
+
+	if (y < WORLD_BOTTOM_Y) {
+		return ID_AIR;
+	}
+	if (bedrock_at(p, x, y, z)) {
+		return p.id_bedrock;
+	}
+	if (biome == B_PILLAR) {
+		return y <= g ? p.id_bedrock : ID_AIR;
+	}
+
+	// SHARP-SLOPE. slope_run is always >= 0 here (worker path hoists it); < 0 would mean recompute,
+	// which the emit loop never asks for.
+	bool slope_fires = false;
+	Vector4i tw;
+	if (slope_run >= 0) {
+		slope_fires = ((slope_run >> 16) & 1) != 0;
+		if (slope_fires) {
+			tw = slope_run_targets(slope_run, g);
+		}
+	} else {
+		slope_fires = slope_fires_only(p, fid, x, z, g);
+		if (slope_fires) {
+			const Vector4 raw = corner_targets(p, fid, x, z);
+			tw = Vector4i(int(cosmos::roundi(double(raw.x))), int(cosmos::roundi(double(raw.y))),
+					int(cosmos::roundi(double(raw.z))), int(cosmos::roundi(double(raw.w))));
+		}
+	}
+	if (slope_fires) {
+		const int lo = cosmos::mini(cosmos::mini(tw.x, tw.y), cosmos::mini(tw.z, tw.w));
+		const int hi = cosmos::maxi(cosmos::maxi(tw.x, tw.y), cosmos::maxi(tw.z, tw.w));
+		if (y >= lo && y <= hi - 1) {
+			const int smod = cc_make_slope(tw.x - y, tw.y - y, tw.z - y, tw.w - y);
+			int smat;
+			if (y >= g) {
+				smat = cap_material(p, biome, x, z, t, g);
+			} else {
+				smat = surface_rule(p, x, y, z, g, biome, c, t);
+			}
+			return with_snow_state(p, fid, with_shore_liquid(p, cc_pack(smat, smod, 0, 0), y, t), g, t);
+		}
+		if (y >= hi) {
+			if (y <= SEA_LEVEL) {
+				return sea_block(p, t, y);
+			}
+			return tree_block_at(p, fid, x, y, z);
+		}
+		int idlo = surface_rule(p, x, y, z, g, biome, c, t);
+		if (idlo == p.id_stone && y < g) {
+			idlo = deep_family(p, x, y, z);
+			idlo = ore_at(p, x, y, z, idlo, biome, c);
+		}
+		return idlo;
+	}
+
+	if (y > g) {
+		if (y == g + 1) {
+			const int64_t cap = surface_cap(p, fid, x, z, g, biome, t);
+			if (cap != ID_AIR) {
+				return with_lip_snow_fill(p, fid,
+						with_snow_state(p, fid, with_shore_liquid(p, cap, y, t), g, t), x, z, g, t);
+			}
+		}
+		const int64_t snow = snow_stack(p, fid, x, y, z, g, t);
+		if (snow != ID_AIR) {
+			return snow;
+		}
+		if (y <= SEA_LEVEL) {
+			return sea_block(p, t, y);
+		}
+		return tree_block_at(p, fid, x, y, z);
+	}
+
+	int id = surface_rule(p, x, y, z, g, biome, c, t);
+	if (id == p.id_stone && y < g) {
+		id = deep_family(p, x, y, z);
+		id = ore_at(p, x, y, z, id, biome, c);
+	}
+	if (y == g) {
+		return with_surface_snow_fill(p, fid,
+				with_snow_state(p, fid, with_shore_liquid(p, smoothed_surface(p, fid, x, z, g, id), y, t), g, t),
+				x, z, g, t);
+	}
+	return id;
+}
+
+// ================================================================================================
+// THE THREE ENTRY POINTS (SEAMLESS-SCALES §7.2). generate_block is STAGED INERT until S3.
+//
+// A note on how they fail while staged, because it is a deliberate choice and not laziness: each
+// returns a value that is OBVIOUSLY broken rather than plausibly correct. Missing terrain and a -1
+// cell id are loud; a plausible-but-subtly-wrong height or an AIR cell would be quiet, and quiet
+// wrongness in worldgen is exactly what the byte-equality gate exists to prevent from ever
+// shipping. None of these is reachable in the shipped build anyway: the class is only instantiated
+// under FP_CPPGEN, which is default-false.
+// ================================================================================================
+
+VoxelGenerator::Result VoxelGeneratorCosmos::generate_block(VoxelQueryData input) {
+	// ENTRY POINT 1 — S1: skeleton. Lands in S3 (resolve_cell + the emit loop), as a thin loop over
+	// resolve_cell_core. An empty buffer here reads as visibly missing terrain: loud, as intended.
+	return Result();
+}
+
+Dictionary VoxelGeneratorCosmos::sample_columns(int fid, PackedInt64Array cells) const {
+	// ENTRY POINT 2 — S1: shape only; lands in S2/S3 as a thin loop over column_profile_core, plus
+	// the junction/ridge treatment so adjacent facets' tiles agree bit-exactly at shared seam columns.
+	//
+	// The empty dictionary is the staged inert value. Do NOT be tempted to "temporarily" fill this
+	// from a quick heightfield approximation to unblock a caller: a second sampler is precisely what
+	// the one-sampler law forbids, and its seam would land on a facet ridge.
+	Dictionary d;
+	d["heights"] = PackedFloat32Array();
+	d["biomes"] = PackedInt32Array();
+	d["water"] = PackedByteArray();
+	d["colors"] = PackedColorArray();
+	d["staged"] = true; // S1 marker: absent once S2/S3 implement this. Gates assert on it.
+	return d;
+}
+
+// A facet id the frozen atlas actually covers. cell_dir indexes facet_frame directly, so an
+// unchecked fid from script would read out of bounds -- checked once at the entry point rather than
+// per core call, keeping the hot path clean while the boundary stays safe.
+bool VoxelGeneratorCosmos::fid_ok(const Parameters &p, int fid) {
+	return !p.faceted || (fid >= 0 && fid < p.facet_count);
+}
+
+Vector4 VoxelGeneratorCosmos::column_profile(int fid, int x, int z) const {
+	// ENTRY POINT 3a (S2 — live). A single core call; no separate implementation. `fid` is ignored
+	// on the flat branch, exactly as the GDScript is.
+	RWLockRead rlock(_params_lock);
+	if (!_params.ready || !fid_ok(_params, fid)) {
+		const float nan = NAN;
+		return Vector4(nan, nan, nan, nan);
+	}
+	return column_profile_core(_params, fid, x, z);
+}
+
+int VoxelGeneratorCosmos::slope_run_of(int fid, int x, int z) const {
+	// The S2 gate surface for SHARP-SLOPE. Mirrors TerrainConfig.slope_run_of's WORKER path: derive
+	// g from the column itself, then the shared predicate.
+	RWLockRead rlock(_params_lock);
+	if (!_params.ready || !fid_ok(_params, fid)) {
+		return -1;
+	}
+	const int g = col_h(_params, fid, x, z);
+	return slope_run_core(_params, fid, x, z, g);
+}
+
+int64_t VoxelGeneratorCosmos::resolve_cell(int fid, int x, int y, int z) const {
+	// ENTRY POINT 3b (S3 — live). Mirrors TerrainConfig.resolve_cell's WORKER path: the column
+	// profile + the hoisted slope run, then the one core. `fid` ignored on the flat branch.
+	RWLockRead rlock(_params_lock);
+	if (!_params.ready || !fid_ok(_params, fid)) {
+		return -1;
+	}
+	const Vector4 prof = column_profile_core(_params, fid, x, z);
+	const int g = int(prof.x);
+	const int slope_run = slope_run_core(_params, fid, x, z, g);
+	return resolve_cell_core(_params, fid, x, y, z, prof, slope_run);
+}
+
+void VoxelGeneratorCosmos::_bind_methods() {
+	ClassDB::bind_method(D_METHOD("setup", "config"), &VoxelGeneratorCosmos::setup);
+	ClassDB::bind_method(D_METHOD("is_ready"), &VoxelGeneratorCosmos::is_ready);
+	ClassDB::bind_method(D_METHOD("get_setup_digest"), &VoxelGeneratorCosmos::get_setup_digest);
+
+	// SEAMLESS-SCALES §7.2 items 2 and 3: the batch sampler and the scalar parity queries. Bound in
+	// S1 -- while they are staged inert -- so the boundary shape is pinned by the gate from the start
+	// and S2/S3 fill in bodies rather than re-architecting an interface under deadline.
+	ClassDB::bind_method(D_METHOD("sample_columns", "fid", "cells"), &VoxelGeneratorCosmos::sample_columns);
+	ClassDB::bind_method(D_METHOD("column_profile", "fid", "x", "z"), &VoxelGeneratorCosmos::column_profile);
+	ClassDB::bind_method(D_METHOD("slope_run_of", "fid", "x", "z"), &VoxelGeneratorCosmos::slope_run_of);
+	ClassDB::bind_method(D_METHOD("resolve_cell", "fid", "x", "y", "z"), &VoxelGeneratorCosmos::resolve_cell);
+}
+
+} // namespace zylann::voxel
