+#ifndef COSMOS_TERRAIN_H
+#define COSMOS_TERRAIN_H
+
+// VOXIVERSE COSMOS L5(a) — the ported worldgen constants and pure column math.
+//
+// THIS FILE IS A TRANSCRIPTION, NOT A DESIGN. Every function here is a line-for-line port of a
+// `TerrainConfig` / `TreeGen` static, and its ONLY correctness criterion is that it returns exactly
+// what the GDScript twin returns, bit for bit. If you find yourself improving an algorithm here,
+// stop: the GDScript is the specification, `verify_cppgen.gd` is the oracle, and a "better" formula
+// is a byte-equality failure. Fix the GDScript first if something is genuinely wrong, then re-port.
+//
+// THE FOUR TRANSCRIPTION TRAPS (all of them have teeth; the first two have already bitten projects
+// like this one):
+//
+//  1. INT WIDTH. GDScript ints are int64, and TerrainConfig._hash01_3d mixes with 2246822519 —
+//     which EXCEEDS int32. Every hash mixer below therefore uses int64_t. Using `int` silently
+//     changes bedrock/strata/ore. This is the single easiest way to break the port.
+//
+//  2. FLOAT WIDTH. GDScript `float` is f64, so intermediates are `double`, never `float`. But the
+//     narrowings GDScript *does* perform are part of the semantics and must be reproduced:
+//       - `Noise::get_noise_*` takes and returns real_t (f32 in a standard build). Passing a double
+//         narrows on the way in and widens on the way out — mirrored here by taking doubles and
+//         letting the same implicit conversions happen.
+//       - `Vector4` has real_t components. GDScript's column_profile and _corner_targets return
+//         Vector4, so their values are ALREADY f32-rounded before anything downstream reads them.
+//         That is why the profile and corner-target types here are Vector4 and not a double quad.
+//
+//  3. DON'T REIMPLEMENT ENGINE MATH. GDScript's `smoothstep`/`lerp` bind straight to
+//     Math::smoothstep / Math::lerp (double overloads). We call the same functions rather than
+//     retyping the formula — smoothstep in particular has an is_equal_approx early-out that a
+//     hand-rolled `s*s*(3-2s)` would miss. Same discipline as not reimplementing FastNoiseLite.
+//
+//  4. NO CUBE TOPOLOGY IN C++. Facet frames arrive as 12 frozen doubles per facet (FacetAtlas._frame)
+//     plus a 2-int offset, so `cell_dir` below is PURE ARITHMETIC. This deliberately follows patch
+//     0003's precedent, whose header records why: topology logic in C++ is "the exact class that
+//     scrambled the M5a shader twice". Sign/index errors are unfixable-by-inspection; frozen numbers
+//     cannot have them.
+
+#include <core/math/math_funcs.h>
+#include <core/math/vector4.h>
+#include <core/math/vector4i.h>
+
+#include <cstdint>
+
+namespace zylann::voxel {
+namespace cosmos {
+
