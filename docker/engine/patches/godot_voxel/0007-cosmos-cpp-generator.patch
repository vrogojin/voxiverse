+constexpr double T_FROZEN_SEA = -8.0;
+
+// CellCodec bit layout (cell_codec.gd). The packed-cell contract; getting any of these wrong is a
+// byte-equality failure by definition.
+constexpr int64_t MAT_MASK = 0xFFFF;
+constexpr int MOD_ANC_BIT = 1 << 8;
+constexpr int MOD_CORNERS_MASK = 0xFF;
+constexpr int MOD_FAM_BIT = 1 << 15;
+constexpr int MOD_FAM_KIND_SHIFT = 12;
+constexpr int MOD_FAM_KIND_MASK = 0x7;
+constexpr int FAM_LAYER = 0;
+constexpr int FAM_SLOPE = 1;
+constexpr int FAM_JUNCTION = 2;
+constexpr int MOD_LAYER_LEVEL_MASK = 0xF;
+constexpr int LAYER_SLAB_MODIFIER = 85;
+constexpr int MOD_SLOPE_BIAS = 3;
+constexpr int LIQ_SHIFT = 48;
+constexpr int LIQ_FIELD_MASK = 0x3F;
+constexpr int LIQ_KIND_MASK = 0x3;
+constexpr int LIQ_WATER = 1;
+constexpr int LIQ_LAVA = 2;
+constexpr int LIQ_LEVEL_SURFACE = 9;
+constexpr int LIQ_LEVEL_FULL = 10;
+constexpr int STATE_SNOW_CAPPED = 1;
+constexpr int STATE_SNOW_FILL_SHIFT = 1;
+constexpr int STATE_SNOW_FILL_MASK = 0xF << STATE_SNOW_FILL_SHIFT;
+constexpr int64_t STATE_MASK = 0xFFFF;
+
+constexpr int ANCHOR_BOTTOM = 0;
+
+// BlockCatalog (godot/src/sim/block_catalog.gd).
+constexpr int ID_AIR = 0;
+
+// GDScript posmod(a, b): result has the sign of b, i.e. ((a % b) + b) % b.
+inline int64_t posmod(int64_t a, int64_t b) {
+	int64_t r = a % b;
+	if ((r != 0) && ((r < 0) != (b < 0))) {
+		r += b;
+	}
+	return r;
+}
+
+inline int clampi(int v, int lo, int hi) {
+	return v < lo ? lo : (v > hi ? hi : v);
+}
+
+inline int mini(int a, int b) {
+	return a < b ? a : b;
+}
+
+inline int maxi(int a, int b) {
+	return a > b ? a : b;
+}
+
+// ---------------------------------------------------------------------------------------------
+// GDScript built-in equivalents. Thin on purpose: each mirrors ONE GDScript global exactly.
+// ---------------------------------------------------------------------------------------------
+
+// GDScript `roundi(x)` == int(round(x)); Godot's round() is half-away-from-zero, which is NOT what
+// nearbyint()/rint() do under the default rounding mode (they are half-to-even). Getting this wrong
+// would flip exactly the .5 corner targets that decide whether a slope fires.
+inline int64_t roundi(double x) {
+	return int64_t(Math::round(x));
+}
+
+inline int64_t floori(double x) {
+	return int64_t(Math::floor(x));
+}
+
+// GDScript `roundf` — same half-away-from-zero rule, kept as a double.
+inline double roundf_gd(double x) {
+	return Math::round(x);
+}
+
+inline double smoothstep(double from, double to, double x) {
+	return Math::smoothstep(from, to, x);
+}
+
+inline double lerp(double from, double to, double w) {
+	return Math::lerp(from, to, w);
+}
+
+inline double clampf(double v, double lo, double hi) {
+	return CLAMP(v, lo, hi);
+}
+
+// ---------------------------------------------------------------------------------------------
+// Hashes. int64_t THROUGHOUT — see trap 1 above.
+// ---------------------------------------------------------------------------------------------
+
+// Port of TerrainConfig._hash01_3d.
+inline double hash01_3d(int64_t ix, int64_t iy, int64_t iz, int64_t salt) {
+	int64_t n = (ix * 374761393 + iy * 668265263 + iz * 2246822519 + salt * 362437) & 0x7FFFFFFF;
+	n = ((n ^ (n >> 13)) * 1274126177) & 0x7FFFFFFF;
+	n = n ^ (n >> 16);
+	return double(n & 0xFFFF) / 65536.0;
+}
+
+// Port of TreeGen._hash01 (the 2D twin; different mix, do not merge with the 3D one).
+inline double tree_hash01(int64_t ix, int64_t iz, int64_t salt) {
+	int64_t n = (ix * 374761393 + iz * 668265263 + salt * 362437) & 0x7FFFFFFF;
+	n = ((n ^ (n >> 13)) * 1274126177) & 0x7FFFFFFF;
+	n = n ^ (n >> 16);
+	return double(n & 0xFFFF) / 65536.0;
+}
+
+// ---------------------------------------------------------------------------------------------
+// Continent spline + biome. Ports of TerrainConfig._knot / _continent_offset / _biome.
+// ---------------------------------------------------------------------------------------------
+
+inline double knot(double c, double c0, double c1, double v0, double v1) {
+	return v0 + (v1 - v0) * (c - c0) / (c1 - c0);
+}
+
+inline double continent_offset(double c) {
+	if (c <= -1.0) {
+		return -14.0;
+	}
+	if (c < -0.45) {
+		return knot(c, -1.0, -0.45, -14.0, -6.0);
+	}
+	if (c < -0.15) {
+		return knot(c, -0.45, -0.15, -6.0, 0.0);
+	}
+	if (c < 0.4) {
+		return knot(c, -0.15, 0.4, 0.0, 2.0);
+	}
+	if (c < 1.0) {
+		return knot(c, 0.4, 1.0, 2.0, 11.0);
+	}
+	return 11.0;
+}
+
+// `h` is HUMIDITY despite the name -- kept as-is to match the GDScript signature it ports.
+inline int biome_of(double c, double t, double h, int g, double mountain) {
+	if (c < -0.32) {
+		return B_OCEAN;
+	}
+	if (c < 0.25 && g >= SEA_LEVEL - 2 && g <= SEA_LEVEL + 2) {
+		return B_BEACH;
+	}
+	if (mountain > MOUNTAIN_BIOME_T) {
+		return B_MOUNTAINS;
+	}
+	if (t > 0.45 && h < -0.45) {
+		return B_BADLANDS;
+	}
+	if (t > 0.45 && h < 0.0) {
+		return B_DESERT;
+	}
+	if (t > 0.15 && h > 0.5) {
+		return B_SWAMP;
+	}
+	if (t < -0.55) {
+		return B_SNOWY;
+	}
+	if (t < -0.15) {
+		return B_TAIGA;
+	}
+	if (h > 0.1) {
+		return B_FOREST;
+	}
+	return B_PLAINS;
+}
+
+// Port of TerrainConfig._latitude_temperature.
+inline double latitude_temperature(double dz, double noise_t) {
+	const double lat_term = 1.0 - 2.0 * Math::abs(dz);
+	return clampf(LAT_GAIN * lat_term + LAT_NOISE_GAIN * noise_t, -1.0, 1.0);
+}
+
+} // namespace cosmos
+} // namespace zylann::voxel
+
+#endif // COSMOS_TERRAIN_H
