+#ifndef VOXEL_GENERATOR_COSMOS_H
+#define VOXEL_GENERATOR_COSMOS_H
+
+// VOXIVERSE COSMOS — L5(a): the C++ worldgen port.
+// Design: docs/COSMOS-STREAM-SCHED-DESIGN.md §2.6 (why) + docs/COSMOS-SEAMLESS-SCALES-DESIGN.md §7
+// (the one-sampler law + the interface contract this class MUST satisfy).
+//
+// WHY THIS EXISTS. Measured on the live web build (2026-07-17): 97 % of all block-generation time
+// is spent in two per-cell classes that are *interpreter-bound*, not algorithm-bound —
+// underground gate-failed at 337.7 ms/block and surface-crossing at 559.8 ms/block, against a
+// 13.7 ms native twin (a ~x25 WASM/GDScript multiplier). Supply is 23-35 blocks/s against a
+// walking demand of ~90-100 blocks/s: supply < demand ALWAYS, and that gap IS the freezes. Every
+// script-side lever was built and measured out — R1 column-bulk and R7 blob-stamp are correct and
+// byte-identical yet moved M4 only -13 %, because the profile pass and loop mechanics still carry
+// the full VM tax. No script-side transformation removes a multiplier; only compilation does.
+//
+// ===========================================================================================
+// THE ONE-SAMPLER LAW (SEAMLESS-SCALES §7.1) — THE ARCHITECTURAL CONSTRAINT ON THIS FILE
+// ===========================================================================================
+//
+//   "Every tier — voxel, skin, far ring, scaled body — must sample the SAME worldgen
+//    implementation, parameterized by stride/LOD; a second implementation of any terrain
+//    quantity is a guaranteed seam."
+//
+// Today the law holds because everything funnels through TerrainConfig.profile_at_dir /
+// facet_profile / resolve_cell — ONE choke point, which is exactly why the tiers agree. THIS CLASS
+// IS THE FIRST REAL RISK OF BIFURCATION, and it must inherit the choke-point property rather than
+// break it. The failure mode to understand before editing: if C++ served the voxel workers while
+// analytic physics (WorldManager.block_id_at -> resolve_cell), the skin tier, the far ring
+// (facet_far_ring.gd:390,434) and the LOD builder kept calling GDScript, we would be maintaining
+// two implementations of resolve_cell/column_profile in parallel. They WILL drift — and a drift
+// between the physics oracle and the rendered mesh is worse than a seam: it is the float-through /
+// fall-through class of bug this project has already fought once.
+//
+// So this class is NOT "the render-buffer generator". It is THE worldgen implementation. The
+// GDScript twin is retained permanently as the byte-equality ORACLE, never as a live second path.
+//
+// STRUCTURAL CONSEQUENCE — ONE CORE, THREE ENTRY POINTS. The private `*_core` functions below are
+// the single implementation of every terrain quantity. Every public entry point is a thin loop
+// over them:
+//
+//     generate_block()   ---\
+//     sample_columns()   ----+--->   column_profile_core
+//     column_profile()   ---/        slope_run_core          (the ONE implementation)
+//     resolve_cell()     ---/        resolve_cell_core
+//
+// DO NOT add a per-caller fast path. A "just for the skin tier" column routine, or a "cheap"
+// approximation for the far ring, IS the second implementation the law forbids — and its seam
+// would surface at a facet ridge, the exact artifact the user has ruled out. If a tier needs
+// coarser data, it passes a bigger stride to the same core; it does not get its own sampler.
+//
+// ===========================================================================================
+// THE CORRECTNESS FENCE
+// ===========================================================================================
+//
+// Byte-equality against the GDScript twin is not a quality metric — it is the entire argument that
+// every tier, and the physics oracle, agree. `verify_cppgen.gd` is the oracle; it is proven able
+// to fail (a 1e-6 perturbation of the C++ noise read was caught), and it is never weakened to make
+// a change pass. If it goes red, this file is wrong.
+//
+// HOW BYTE-EQUALITY IS ACHIEVED (the two decisions that make it tractable):
+//
+//  1. NOISE IS NOT REIMPLEMENTED. `setup()` takes the very `FastNoiseLite` objects
+//     `TerrainConfig._ensure_noise()` built on the main thread, as `Ref<Noise>`. C++ then calls the
+//     SAME `get_noise_2d/3d` virtual the GDScript path calls, on the SAME instance. Bit-matching is
+//     therefore by construction rather than by careful reimplementation — the class of bug that
+//     would otherwise sink this port (a subtly different fBm accumulation order) cannot occur.
+//     PROVEN, not assumed: verify_cppgen's G-CG-NOISE compares all six noises across the boundary
+//     at 17 significant digits and they agree exactly. Do not "simplify" this into passing noise
+//     PARAMETERS and rebuilding the noise C++-side; that reintroduces precisely the drift it avoids.
+//
+//  2. FLOAT WIDTH IS MIRRORED, NOT CHOSEN. GDScript `float` is f64, so every intermediate here is
+//     `double` — never `float`. The narrowing points are mirrored exactly where GDScript narrows:
+//     `real_t` (f32 in a standard build) at the noise call boundary in and out, and `Vector4`
+//     (real_t components) when a column profile is stored. Using `float` for an intermediate, or
+//     skipping a narrowing GDScript performs, is a byte-equality failure — and a legitimate one.
+//
+//     RELATED TRAP, for whoever ports the hashes (S3): GDScript ints are **int64**, and
+//     TerrainConfig._hash01_3d's constant 2246822519 EXCEEDS int32. The hash mixers must use
+//     `int64_t`, not `int`, or bedrock/strata/ore silently diverge. This is the single easiest way
+//     to break byte-equality in this port.
+//
+// THE FROZEN-EPOCH CONTRACT IS SACRED — and §7.2's purity contract makes it structural. Every table
+// crosses the boundary ONCE, in `setup()`, on the main thread, before any worker touches this
+// generator; the worker then reads immutable C++-side data only. Nothing here may lazily
+// first-touch on a worker: that is this project's worst data-race class (WGC §7.4). No callbacks
+// into script, no engine singletons, const after setup. A facet/face flip installs a NEW generator,
+// it never mutates a live one — exactly as the GDScript generator's gen_face/gen_facet epoch works.
+
+#include "../../util/godot/classes/noise.h"
+#include "../../util/thread/rw_lock.h"
+#include "../voxel_generator.h"
+
+#include <core/math/vector4i.h>
+#include <core/variant/typed_array.h>
+
+namespace zylann::voxel {
+
+class VoxelGeneratorCosmos : public VoxelGenerator {
+	GDCLASS(VoxelGeneratorCosmos, VoxelGenerator)
+
+public:
+	VoxelGeneratorCosmos();
+	~VoxelGeneratorCosmos();
+
+	// --- setup / epoch --------------------------------------------------------------------------
+
+	// Freeze this epoch's immutable inputs. MAIN THREAD ONLY, exactly once, before any worker runs.
+	// `config` mirrors the frozen members of the GDScript generator one-for-one (noise stack, block
+	// id table, appearance/ARID tables, facet/face epoch, flags). Returns false and stays disabled if
+	// anything required is missing -- a half-configured generator must never emit, because "emits
+	// something slightly wrong" is indistinguishable from a byte-equality failure at the gate but far
+	// harder to diagnose in the field.
+	bool setup(Dictionary config);
+
+	// True once `setup()` has succeeded. Every entry point is inert until then.
+	bool is_ready() const;
+
+	// S1 gate surface: echoes back what `setup()` actually received (table sizes, seed, epoch), so
+	// `verify_cppgen.gd` can prove the frozen tables crossed the boundary intact rather than assume
+	// it. Also round-trips one sample per noise, which is what proves decision (1) end-to-end.
+	// Cheap, main-thread, diagnostic only -- nothing in any emit path reads this.
+	Dictionary get_setup_digest() const;
+
+	// --- ENTRY POINT 1: the voxel worker path (SEAMLESS-SCALES §7.2 item 1) ---------------------
+	// The whole inner path of module_world.gd's generated `_generate_block`: frozen tables in once at
+	// setup, no per-cell script calls. `input.lod` carries the stride (s = 1 << lod), mirroring the
+	// GDScript generator's gen_lod_probe; at lod0 s == 1 and this is byte-identical to shipped.
+	Result generate_block(VoxelQueryData input) override;
+
+	// --- ENTRY POINT 2: batch heightfield sampling (SEAMLESS-SCALES §7.2 item 2) ----------------
+	//
+	// The load-bearing addition of the seamless-scales design: what lets the skin tier, the extension
+	// rings, the backstop refresh and future Moon tiles cost milliseconds *and* agree with the voxel
+	// surface exactly -- the mechanical embodiment of "no stitches". ONE call per skin tile /
+	// backstop grid (33^2-65^2 columns). Target: a 64x64 pitch-2 tile <= ~1 ms.
+	//
+	// BATCH IS THE POINT, not a micro-optimisation. §2.6 forbids per-cell GDScript->C++ round trips
+	// because their call overhead eats the entire win; a scalar-per-column API would simply recreate
+	// that cost at skin-tile scale. Callers hand over a whole tile's columns at once.
+	//
+	// `cells` packs (x, z) per column into an int64. Returns
+	// {heights: PackedFloat32Array, biomes: PackedInt32Array, water: PackedByteArray,
+	//  colors: PackedColorArray}.
+	//
+	// MUST apply the ridge/junction treatment (junction_modify) so adjacent facets' tiles agree
+	// BIT-EXACTLY at shared seam columns -- otherwise every facet ridge becomes a visible crack in
+	// the skin tier, which is the stitch this whole design exists to remove.
+	//
+	// S2/S3: implement as a thin loop over column_profile_core. NOT as its own sampler.
+	Dictionary sample_columns(int fid, PackedInt64Array cells) const;
+
+	// --- ENTRY POINT 3: scalar parity queries (SEAMLESS-SCALES §7.2 item 3) ---------------------
+	//
+	// So block_id_at / height_at -- the PHYSICS TRUTH -- can route to the SAME core under the port
+	// flag instead of keeping a live second implementation in GDScript. This is the item that keeps
+	// the law satisfied: without it the port bifurcates physics from render, which buys the
+	// float-through class of bug rather than a merely visible seam.
+	//
+	// Scalar, hence boundary-cost-bound: these are for the QUERY path, which already makes one call
+	// per query today. Never use them for bulk sampling -- bulk goes through sample_columns.
+	Vector4 column_profile(int fid, int x, int z) const;
+	int64_t resolve_cell(int fid, int x, int y, int z) const;
+
+private:
+	static void _bind_methods();
+
+	struct Parameters;
+
+	// --- THE ONE CORE (see the one-sampler law above) -------------------------------------------
+	// The single implementation of every terrain quantity, shared by all entry points. Pure: reads
+	// only `p` (the frozen epoch) and its arguments. No script callbacks, no singletons, thread-safe
+	// const after setup -- §7.2's purity contract, expressed as a signature rather than a promise.
+	//
+	// The profile type is `Vector4` deliberately: it matches GDScript's column_profile return type
+	// EXACTLY, including that its components are real_t (f32). That narrowing is part of the
+	// SEMANTICS, not a storage detail -- GDScript's downstream resolve_cell reads c/t back out of a
+	// Vector4, so the f32 round-trip already happened there and must happen here too. Compute in
+	// double, land in Vector4, read back.
+	static Vector4 column_profile_core(const Parameters &p, int fid, int x, int z);
+	static int slope_run_core(const Parameters &p, int fid, int x, int z, int g);
+	static int64_t resolve_cell_core(
+			const Parameters &p, int fid, int x, int y, int z, const Vector4 &prof, int slope_run);
+
+	// Core internals (S2). All static + pure over `p`; see cosmos_terrain.h for the transcription
+	// traps. Named after the TerrainConfig / TreeGen statics they port, so a reader can diff them
+	// against the GDScript side by side -- which is the only way this stays byte-equal over time.
+	static void cell_dir(const Parameters &p, int fid, int x, int z, double &out_x, double &out_y, double &out_z);
+	static double mountain_factor(const Parameters &p, double c, double fx, double fz);
+	static double mountain_factor3(const Parameters &p, double c, double px, double py, double pz);
+	static int height_c(const Parameters &p, double c, double fx, double fz);
+	static int height_c3(const Parameters &p, double c, double px, double py, double pz, double mtn);
+	static Vector4 profile_at_dir(const Parameters &p, double dx, double dy, double dz, double rr);
+	static int col_h(const Parameters &p, int fid, int x, int z);
+	static bool fid_ok(const Parameters &p, int fid);
+
+	static void tree_base_pos(int gx, int gz, int &out_bx, int &out_bz);
+	static int tree_species_for(int biome, int gx, int gz);
+	static bool tree_has_tree(const Parameters &p, int fid, int gx, int gz);
+	static int tree_oak_block(int gx, int gz, int dx, int y, int dz, int gy, int log_id, int leaf_id);
+	static int tree_spruce_block(const Parameters &p, int gx, int gz, int dx, int y, int dz, int gy);
+	static int tree_block_at(const Parameters &p, int fid, int x, int y, int z);
+
+	static Vector4 corner_targets(const Parameters &p, int fid, int x, int z);
+	static bool slope_fires_only(const Parameters &p, int fid, int x, int z, int g);
+	static int slope_run_pack(const Vector4i &tw, int g);
+	static Vector4i slope_run_targets(int r, int g);
+
+	// S3 — resolve_cell + its helpers, ported from TerrainConfig. Every one names the GDScript static
+	// it transcribes. All static + pure over the frozen `p`.
+	static bool bedrock_at(const Parameters &p, int x, int y, int z);
+	static int sea_liquid_kind(double t);
+	static int64_t sea_block(const Parameters &p, double t, int y);
+	static int surface_rule(const Parameters &p, int x, int y, int z, int g, int biome, double c, double t);
+	static int biome_top(const Parameters &p, int biome, int x, int z);
+	static int underwater_floor(const Parameters &p, int biome, int x, int z, double t);
+	static int filler_depth(int biome);
+	static int biome_filler(const Parameters &p, int biome, int x, int y, int z, int depth, double t);
+	static int band_color(const Parameters &p, int x, int y, int z);
+	static int deep_family(const Parameters &p, int x, int y, int z);
+	static int strata_at(const Parameters &p, int x, int y, int z);
+	static int strata_variant_of(const Parameters &p, int lx, int ly, int lz, int cy);
+	static int ore_at(const Parameters &p, int x, int y, int z, int host, int biome, double c);
+	static double ore_density(int i, int y);
+	static double eff_weight(int i, int y, int biome, double c);
+	static int pick_ore(const Parameters &p, int y, int biome, double c, int lx, int ly, int lz);
+	static int ore_apply(const Parameters &p, int ore, int y, int host);
+
+	static double climate_base(double t);
+	static double surface_temperature(int surface_y, double t);
+	static int snow_depth(const Parameters &p, int fid, int x, int z, int g, double t);
+	static double h_ref(const Parameters &p, int fid, int x, int z);
+	static int64_t snow_stack(const Parameters &p, int fid, int x, int y, int z, int g, double t);
+
+	static Vector4 quantized_targets(const Parameters &p, int fid, int x, int z);
+	static double q_target(double raw_t, bool whole);
+	static bool col_fires(const Parameters &p, int fid, int X, int Z);
+	static int modifier_from_targets(const Vector4 &targets, int base_y);
+	static int cap_material(const Parameters &p, int biome, int x, int z, double t, int g);
+	static int64_t surface_cap(const Parameters &p, int fid, int x, int z, int g, int biome, double t);
+	static int64_t smoothed_surface(const Parameters &p, int fid, int x, int z, int g, int mat);
+
+	// CellCodec / ShapeCodec, ported. Only the pack/compose path resolve_cell exercises.
+	static int shape_make_modifier(int c00, int c10, int c11, int c01, int anc);
+	static int cc_make_slope(int d00, int d10, int d11, int d01);
+	static int cc_canonical_slope(int d00, int d10, int d11, int d01);
+	static int cc_slope_raw(int d00, int d10, int d11, int d01);
+	static int cc_make_layer(int level);
+	static int64_t cc_pack(int mat, int modifier, int state, int liquid);
+	static int cc_make_liquid(int kind, int level);
+	static int64_t cc_with_liquid(int64_t v, int kind, int level);
+	static int64_t cc_with_state(int64_t v, int bits);
+	static int64_t cc_with_snow_fill(int64_t v, int level);
+	static int cc_modifier(int64_t v);
+	static int cc_mat(int64_t v);
+	static int cc_state(int64_t v);
+	static int cc_liquid_field(int64_t v);
+	static int64_t cc_canonical(const Parameters &p, int64_t v);
+	static int cc_canonical_modifier(const Parameters &p, int material, int modifier_bits);
+	static int cc_validate_state(const Parameters &p, int material, int state_bits);
+	static int cc_canonical_snow_fill(const Parameters &p, int material, int canonical_mod, int state_bits);
+	static int cc_canonical_liquid(const Parameters &p, int material, int canonical_mod, int liquid);
+	static double solidity_of(const Parameters &p, int mat);
+	static int state_mask_of(const Parameters &p, int lrid);
+
+	static int64_t with_shore_liquid(const Parameters &p, int64_t v, int y, double t);
+	static int64_t with_snow_state(const Parameters &p, int fid, int64_t v, int g, double t);
+	static int64_t with_surface_snow_fill(const Parameters &p, int fid, int64_t v, int x, int z, int g, double t);
+	static int64_t with_lip_snow_fill(const Parameters &p, int fid, int64_t v, int x, int z, int g, double t);
+
+	// S2 gate surface: the ported slope run for a column, so verify_cppgen can compare it against
+	// GDScript's slope_run_of. Exposed via ClassDB alongside the §7.2 entry points.
+public:
+	int slope_run_of(int fid, int x, int z) const;
+
+private:
+
+	// The immutable per-epoch snapshot. Written once by `setup()` under `_params_lock`, read by every
+	// worker thereafter. Mirrors VoxelGeneratorNoise2D's Parameters/RWLock idiom, which is the
+	// module's established pattern for exactly this.
+	struct Parameters {
+		bool ready = false;
+
+		// The SAME instances TerrainConfig._ensure_noise() built (see decision 1 above).
+		Ref<Noise> hills;
+		Ref<Noise> detail;
+		Ref<Noise> continent;
+		Ref<Noise> temperature;
+		Ref<Noise> humidity;
+		Ref<Noise> mountain;
+
+		int seed = 0;
+
+		// Frozen epoch, mirroring the GDScript generator's members of the same names.
+		int gen_face = 0;
+		int gen_n = 0;
+		int gen_facet = -1;
+		bool flat_world = true;
+
+		// World-shape flags, snapshotted from CubeSphere at setup. Consts in GDScript; frozen ints
+		// here, because a `const` there is a runtime value to us.
+		bool faceted = false;
+		bool m5c_corner = false;
+
+		// COSMOS FACETED: the facet atlas as FROZEN NUMBERS, never as topology logic. `facet_frame` is
+		// FacetAtlas._frame (12 doubles per facet: origin, du, dv, dw) and `facet_off` is
+		// FacetAtlas._off (2 ints per facet); together they make cell_dir() pure arithmetic. This
+		// follows patch 0003's precedent deliberately -- its header records that cube topology in C++
+		// is "the exact class that scrambled the M5a shader twice". Frozen numbers cannot get a sign
+		// or an index wrong; re-derived topology can.
+		PackedFloat64Array facet_frame;
+		PackedInt32Array facet_off;
+		double facet_r_blocks = 0.0;
+		// Facets the frozen atlas covers. ONE generator can sample ANY of them: §7.2's sample_columns
+		// takes an `fid` precisely so a skin tile can cover facets other than the one the voxel workers
+		// are homed on. gen_facet is this epoch's HOME facet, not a limit on what may be sampled.
+		int facet_count = 0;
+
+		// TreeGen material ids (BlockCatalog). Frozen: BlockCatalog.id_of() is a main-thread lookup and
+		// must never be reached from a worker.
+		int id_wood = 0;
+		int id_leaf = 0;
+		int id_spruce_log = 0;
+		int id_spruce_leaf = 0;
+		int id_birch_log = 0;
+		int id_birch_leaf = 0;
+
+		// Frozen appearance tables (baked main-thread by the loader). Cross once, read-only after.
+		PackedInt32Array cube_arid;
+		PackedInt32Array gen_arid;
+		PackedInt32Array snow_arid;
+		PackedInt32Array layer_arid;
+		PackedInt32Array slope_arid;
+		PackedInt32Array snow_slope_arid;
+		PackedInt32Array carve_arid;
+		PackedInt32Array carve_snow_arid;
+		PackedInt32Array surface_arid;
+
+		// Frozen material ids resolved from BlockCatalog (TerrainConfig._ensure_ids' outputs).
+		PackedInt32Array block_ids;
+
+		int model_count = 0;
+		bool waterlog = false;
+
+		// S3: material ids resolve_cell projects to, frozen from TerrainConfig.material_tables().
+		int id_bedrock = 0, id_deepslate = 0, id_water = 0, id_lava = 0, id_ice = 0;
+		int id_sand = 0, id_red_sand = 0, id_gravel = 0, id_sandstone = 0, id_red_sandstone = 0;
+		int id_snow = 0, id_mud = 0, id_podzol = 0, id_sulfur = 0, id_cinnabar = 0;
+		int id_stone = 0, id_dirt = 0, id_grass = 0;
+		PackedInt32Array strata_seq;  // 6
+		PackedInt32Array band_seq;    // 7
+		PackedInt32Array ore_stone;   // 8
+		PackedInt32Array ore_deep;    // 8
+		// Per-lrid solidity + state mask, indexed by material id (for CellCodec.canonical()).
+		PackedFloat64Array solidity;
+		PackedInt32Array state_mask;
+		int liquid_lrid_water = -1;
+		int liquid_lrid_lava = -1;
+		int block_count = 0;
+	};
+
+	Parameters _params;
+	mutable RWLock _params_lock;
+};
+
+} // namespace zylann::voxel
+
+#endif // VOXEL_GENERATOR_COSMOS_H
