+// COSMOS FS2 (§3.2): the per-column datum shift S. EXACT mirror of FacetAtlas.datum_shift -- p0 is the
+// column base point on the facet plane (cell centre x+0.5, z+0.5, y=0), b = p0.n_hat (the plane offset),
+// and s solves |p0 + s*n_hat| = R for s >= 0. round() matches GDScript's round-half-away-from-zero.
+int VoxelGeneratorCosmos::datum_shift(const Parameters &p, int fid, int x, int z) {
+	if (!p.radial_datum) {
+		return 0;
+	}
+	const int f = fid * 12;
+	const double fx = double(x) + 0.5 - double(p.facet_off[fid * 2]);
+	const double fz = double(z) + 0.5 - double(p.facet_off[fid * 2 + 1]);
+	const double p0x = p.facet_frame[f + 0] + fx * p.facet_frame[f + 3] + fz * p.facet_frame[f + 9];
+	const double p0y = p.facet_frame[f + 1] + fx * p.facet_frame[f + 4] + fz * p.facet_frame[f + 10];
+	const double p0z = p.facet_frame[f + 2] + fx * p.facet_frame[f + 5] + fz * p.facet_frame[f + 11];
+	const double b = p0x * p.facet_frame[f + 6] + p0y * p.facet_frame[f + 7] + p0z * p.facet_frame[f + 8];
+	const double r = p.facet_r_blocks;
+	double disc = b * b + r * r - (p0x * p0x + p0y * p0y + p0z * p0z);
+	if (disc < 0.0) {
+		disc = 0.0;
+	}
+	return int(Math::round(-b + Math::sqrt(disc)));
+}
