+// COSMOS FS2′ (docs/COSMOS-FACET-SEAMS-V2.md §2.2.1): install/clear the frozen-per-facet datum bake. Parsed from
+// FacetAtlas.datum_bake_params; written under the parameters write-lock so the mesh workers pick up the whole blob
+// atomically via their build() snapshot. enabled=false (or an empty dict) restores the plain flat mesher exactly.
+void VoxelMesherBlocky::set_facet_datum_bake(Dictionary d) {
+	FacetDatumBakeParams fd;
+	fd.enabled = bool(d.get("enabled", false));
+	if (fd.enabled) {
+		fd.R = double(d.get("R", 1.0));
+		const PackedFloat64Array o = d.get("o", PackedFloat64Array());
+		const PackedFloat64Array du = d.get("du", PackedFloat64Array());
+		const PackedFloat64Array dv = d.get("dv", PackedFloat64Array());
+		const PackedFloat64Array nh = d.get("nhat", PackedFloat64Array());
+		for (int k = 0; k < 3; ++k) {
+			if (k < o.size()) {
+				fd.o[k] = o[k];
+			}
+			if (k < du.size()) {
+				fd.du[k] = du[k];
+			}
+			if (k < dv.size()) {
+				fd.dv[k] = dv[k];
+			}
+			if (k < nh.size()) {
+				fd.nhat[k] = nh[k];
+			}
+		}
+		const PackedInt32Array off = d.get("off", PackedInt32Array());
+		for (int k = 0; k < 2 && k < off.size(); ++k) {
+			fd.off[k] = off[k];
+		}
+	}
+	RWLockWrite wlock(_parameters_lock);
+	_parameters.facet_datum = fd;
+}
+
+// COSMOS FS2′: the continuous per-column datum lift s at CONTINUOUS lattice coords (vx, vz) — EXACT mirror of
+// FacetAtlas.datum_lift. p0 = o + (vx−offx)·du + (vz−offz)·dv is the column point on the facet plane; b = p0·n̂;
+// s solves |p0 + s·n̂| = R for s ≥ 0. Pure arithmetic, no branches on chart topology (thread-safe on the snapshot).
+static inline double facet_datum_lift(const VoxelMesherBlocky::FacetDatumBakeParams &p, double vx, double vz) {
+	const double fx = vx - double(p.off[0]);
+	const double fz = vz - double(p.off[1]);
+	const double p0x = p.o[0] + fx * p.du[0] + fz * p.dv[0];
+	const double p0y = p.o[1] + fx * p.du[1] + fz * p.dv[1];
+	const double p0z = p.o[2] + fx * p.du[2] + fz * p.dv[2];
+	const double b = p0x * p.nhat[0] + p0y * p.nhat[1] + p0z * p.nhat[2];
+	double disc = b * b + p.R * p.R - (p0x * p0x + p0y * p0y + p0z * p0z);
+	if (disc < 0.0) {
+		disc = 0.0;
+	}
+	return -b + std::sqrt(disc);
+}
