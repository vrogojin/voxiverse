+	// COSMOS FS2′ (docs/COSMOS-FACET-SEAMS-V2.md §2.2.1): the facet DATUM BAKE. Lift every near-mesh vertex by the
+	// CONTINUOUS per-column datum s along the facet-lattice up axis (local +Y) so the flat-lattice near field renders
+	// at the radial surface R+s — the voxel CONTENT is untouched (positions only, no re-index). s is C∞ per column,
+	// so the surface is crack-free between blocks (each vertex uses its OWN fractional x,z). Mutually exclusive with
+	// the curved cosmos bake above (faceted mode ⇒ cosmos.enabled is false). Disabled ⇒ the flat mesher is byte-
+	// identical. Runs on the mesh worker with a per-mesher frozen snapshot (thread-safe). Normals are left as the
+	// flat-cube normals (the ≤2° lift tilt is cosmetically negligible in this ambient-lit scene — §2.1).
+	if (params.facet_datum.enabled) {
+		const FacetDatumBakeParams &fd = params.facet_datum;
+		const Vector3i wo = input.origin_in_voxels; // block's global facet-lattice voxel origin
+		for (Arrays &arrays : arrays_per_material) {
+			const unsigned int vcount = (unsigned int)arrays.positions.size();
+			for (unsigned int i = 0; i < vcount; ++i) {
+				Vector3f lp = arrays.positions[i];
+				const double vx = double(wo.x) + double(lp.x);
+				const double vz = double(wo.z) + double(lp.z);
+				lp.y += (float)facet_datum_lift(fd, vx, vz);
+				arrays.positions[i] = lp;
+			}
+		}
+	}
