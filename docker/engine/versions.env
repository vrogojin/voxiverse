# VOXIVERSE engine version pins — single source of truth.
# Sourced by scripts/build.sh and scripts/export-web.sh.
#
# WHY THESE EXACT VERSIONS:
#   GODOT_REF   godot_voxel v1.4.1 targets Godot 4.4.1.stable (Zylann release notes).
#   VOXEL_REF   v1.4.1 is the godot_voxel release paired with Godot 4.4.1.
#   EMSDK_VERSION  Godot 4.4.1-stable CI (.github/workflows/web_builds.yml) pins
#               EM_VERSION=3.1.64. The export template and the engine MUST be built
#               with the same emscripten version — mismatches are the #1 web failure.
GODOT_REF=4.4.1-stable
VOXEL_REF=v1.4.1
EMSDK_VERSION=3.1.64

# Web Emscripten pthread pool size (preallocated Web Workers). Single source of truth:
# build-engine.sh passes this to scons as pthread_pool_size=, wired into the web build by
# engine patch docker/engine/patches/godot/0001-web-pthread-pool-size-option.patch (the
# stock literal was 8). COSMOS FP-M1b (COSMOS-FP-M1-DESIGN §9) raises it to 16 so voxel
# workers scale with the visitor's core count without exhausting the pool
# (worst case voxel<=10 + WTP 2 + audio/IO/spare<=3 = 15 < 16). Revert knob: set back to 8.
WEB_PTHREAD_POOL=16

# Web WASM malloc implementation. Single source of truth: build-engine.sh passes this to scons as
# malloc=, wired into the web build by engine patch docker/engine/patches/godot/0002-web-malloc-option.patch
# (stock Godot sets no -sMALLOC, so Emscripten defaults to dlmalloc).
#
# WHY mimalloc: dlmalloc serialises every allocation through ONE GLOBAL LOCK. Our voxel workers do
# ~500-2000 heap ops per generated block, so the workers + main thread convoy on that lock, and since
# the browser main thread cannot Atomics.wait, contended locks BUSY-WAIT on main and burn the rAF
# budget. Measured live (docs/COSMOS-WALK-PERF-DESIGN.md): all 6 pool threads read ACTIVE on
# GenerateBlock yet only ~40 blocks/s drain, and phys_ms inflates 4.3 -> 44.5 ms for IDENTICAL
# physics code purely because workers are busy. mimalloc uses per-thread heaps and removes the convoy.
# Requires emsdk >= 3.1.50 (we pin 3.1.64). REVERT KNOB: set back to dlmalloc and rebuild (~24 min).
#
# NEVER-OOM: mimalloc reserves per-thread segments => higher baseline WASM heap. This is a
# memory-costly upgrade: it MUST be A/B'd against a dlmalloc build with peak heap measured, and
# REJECTED if the baseline grows past the ledgered ceiling. Memory safety outranks frame time.
WEB_MALLOC=mimalloc

# Docker image tag for the build toolchain.
ENGINE_IMAGE=voxiverse/godot-build:4.4
# Godot version string as it appears in the export_templates/<ver>/ directory.
GODOT_TEMPLATE_VERSION=4.4.1.stable
