# VOXIVERSE engine version pins — single source of truth.
# Sourced by scripts/build.sh and scripts/export-web.sh.
#
# WHY THESE EXACT VERSIONS:
#   GODOT_REF   godot_voxel v1.4.1 targets Godot 4.4.1.stable (Zylann release notes).
#   VOXEL_REF   v1.4.1 is the godot_voxel release paired with Godot 4.4.1.
#   EMSDK_VERSION  Godot 4.4.1-stable CI (.github/workflows/web_builds.yml) pins
#               EM_VERSION=3.1.64. The export template and the engine MUST be built
#               with the same emscripten version — mismatches are the #1 web failure.
GODOT_REF=4.4.1-stable
VOXEL_REF=v1.4.1
EMSDK_VERSION=3.1.64

# Web Emscripten pthread pool size (preallocated Web Workers). Single source of truth:
# build-engine.sh passes this to scons as pthread_pool_size=, wired into the web build by
# engine patch docker/engine/patches/godot/0001-web-pthread-pool-size-option.patch (the
# stock literal was 8). COSMOS FP-M1b (COSMOS-FP-M1-DESIGN §9) raises it to 16 so voxel
# workers scale with the visitor's core count without exhausting the pool
# (worst case voxel<=10 + WTP 2 + audio/IO/spare<=3 = 15 < 16). Revert knob: set back to 8.
WEB_PTHREAD_POOL=16

# Docker image tag for the build toolchain.
ENGINE_IMAGE=voxiverse/godot-build:4.4
# Godot version string as it appears in the export_templates/<ver>/ directory.
GODOT_TEMPLATE_VERSION=4.4.1.stable
