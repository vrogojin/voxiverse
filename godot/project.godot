; Engine configuration file.
; VOXIVERSE — grass test environment (Godot 4.4)
;
; Renderer is LOCKED to the GL Compatibility backend: it is the most reliable
; path for the Web/HTML5 export the project ships to voxiverse.game-host.org.

config_version=5

[application]

config/name="VOXIVERSE"
config/description="Voxel immersive simulation engine — grass test environment."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://assets/textures/pack/grass.png"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
; Web export: allow the canvas to grab keyboard focus on click.
window/per_pixel_transparency/allowed=false

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
; Even, flat ambient look — no directional sun, no shadows.
lights_and_shadows/use_physical_light_units=false
textures/vram_compression/import_etc2_astc=true

[physics]

; Web / low-FPS SAFETY CAP on physics sub-step catch-up (the "breaking must never tank the
; frame" rule). At the engine default of 8, a single slow RENDER frame (a godot_voxel mesh
; upload spike, a GL-compat pipeline compile) lets the physics server run up to 8 sub-steps
; THAT frame to catch back up to real time — each sub-step re-solving every falling VoxelBody
; against the ~1300-box ground collider. So one render hitch is MULTIPLIED into a physics
; stall, which drops the next frame, which needs even more catch-up: the spiral that pinned us
; at 7-30 fps whenever a tree was falling. Capped at 2, a render spike costs at most 2 physics
; sub-steps; under sustained low FPS the loose debris simply falls in slight slow-motion
; (game-time dilation) instead of freezing the whole game. A voxel sandbox tolerates a block
; settling a hair slower far better than a 9 fps freeze — the settle logic is time-based, not
; frame-based, so behaviour is unchanged, only its worst-case per-frame cost is bounded.
common/max_physics_steps_per_frame=2

[voxel]

; godot_voxel (Zylann) VoxelEngine task-pool sizing.
; count = clamp(round(ratio_over_max * hw), minimum, max(hw - margin_below_max, minimum))
;   (voxel_engine.cpp:49-52; hw = Thread::get_hardware_concurrency()).
;
; COSMOS FP-M1b (COSMOS-FP-M1-DESIGN §9.1) makes the voxel worker count scale with the
; visitor's core count instead of the old fixed 4-pin (ratio 0.0 -> 4 on every device).
; The old pin was only ever a WEB constraint: the web pthread pool is FIXED and
; pre-allocated, and over-requesting it errors "thread pool is exhausted" -> meshing
; deadlock -> blank world. FP-M1b removes that ceiling two ways so scaling is safe:
;   1. The web template now bakes PTHREAD_POOL_SIZE=16 (was 8) — engine patch
;      docker/engine/patches/godot/0001 + versions.env WEB_PTHREAD_POOL=16.
;   2. godot_voxel patch 0005 clamps the web-reported hardware_concurrency to 14
;      (the formula has no absolute-max knob), so N_voxel maxes at 10.
; Resulting web N_voxel by cores: hw=2->3, hw=4->3, hw=8->6, hw=12->8, hw>=14->10.
; Worst-case pool occupancy: voxel(<=10) + WorkerThreadPool(2) + audio/IO/spare(<=3)
; = 15 < 16 pool slots. This file is SHARED native+web: native has no pool ceiling, so
; ratio-scaling simply gives native visitors more workers on bigger machines — safe.
; NOTE: minimum=3, not 4 — on a 1-2 core device the min clamp wins and a slight
; oversubscription (3 workers) is accepted; the 16-slot pool has ample room. The
; count/* keys need only a re-export (baked into the exported project); the
; PTHREAD_POOL_SIZE change needs the ~24-min engine rebuild.
threads/count/minimum=3
threads/count/ratio_over_max=0.7
threads/count/margin_below_max=1
; Main-thread budget godot_voxel spends per frame APPLYING finished meshes (upload +
; scene-tree insert). At 12 ms that is ~72% of a 60fps frame → it starves render/input
; while streaming, so movement stutters. This is the DOWNSTREAM choke once >=3 workers
; generate faster than one frame can apply. Raised 4→6 ms (~36% of a 60fps frame) to let
; the extra worker's output actually reach the screen faster — the near field fills quicker
; after a seam-cross flip, at a small, bounded smoothness cost the user explicitly opted into
; (faster fill > marginal extra smoothness here). Still well under the ~12 ms stutter regime;
; finished meshes beyond the budget just apply over the next frame. Drop back to 4 if 6 ever
; reads as choppy.
threads/main/time_budget_ms=6
