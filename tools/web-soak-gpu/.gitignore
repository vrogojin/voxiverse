# Tier-B web-soak-gpu — never commit deps, browsers, or run outputs.
node_modules/
package-lock.json
results/
*.log
# Screenshots + JSON series are run artefacts, not source.
out/
screenshots/
# The stored regression baseline IS committed (baseline/baseline.json) so it is
# NOT ignored here — a fresh baseline is written to results/ and promoted by hand.

# ── Vast.ai turnkey flow: never commit secrets or run state ──────────────────────
# The instance state file (id + $/hr for teardown) is written under results/ (already
# ignored) but pin it explicitly in case results/ is overridden with --state-file.
vast-instance.env
*.env
# Vast.ai API keys — the CLI reads ~/.config/vastai/vast_api_key; never keep one here.
vast_api_key
*.api_key
.vast_api_key
# Standalone vast.py is fetched on demand when the host has no pip-installed vastai.
lib/vast.py
